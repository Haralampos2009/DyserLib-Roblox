    vTrack.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            vDrag = true
            if settingsP then settingsP.ScrollingEnabled = false end
            setVol((i.Position.X-vTrack.AbsolutePosition.X)/vTrack.AbsoluteSize.X)
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if vDrag and i.UserInputType == Enum.UserInputType.MouseMovement then
            setVol((i.Position.X-vTrack.AbsolutePosition.X)/vTrack.AbsoluteSize.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if vDrag and i.UserInputType == Enum.UserInputType.MouseButton1 then 
            vDrag = false 
            if settingsP then settingsP.ScrollingEnabled = true end
        end
    end)
    regSearch("Volume", "Settings", volRow)
    end
end

