-- ===================== SOUND SYSTEM =====================
local uiSoundGroup = Instance.new("SoundGroup")
uiSoundGroup.Name = "DyserMenuSounds"
uiSoundGroup.Volume = 0.5 
uiSoundGroup.Parent = SoundService

local sfxEnabled = true
local function mksfx(id, vol, pitch)
    local ok, s = pcall(function()
        local snd = Instance.new("Sound")
        snd.SoundId = "rbxassetid://"..tostring(id)
        snd.Volume = vol or 3.0 
        snd.PlaybackSpeed = pitch or 1
        snd.SoundGroup = uiSoundGroup 
        snd.Parent = SoundService
        return snd
    end)
    return ok and s or nil
end

local SFX = {
    hover     = mksfx(4590662766, 1.0, 2.5),
    click     = mksfx(4590662766, 3.0, 1.0),
    toggleOn  = mksfx(4590662766, 2.5, 1.5),
    toggleOff = mksfx(4590662766, 2.5, 1.1),
    slider    = mksfx(4590662766, 1.5, 2.0),
    open      = mksfx(4590662766, 4.0, 0.75),
}

local function playsfx(key)
    if not sfxEnabled then return end
    local s = SFX[key]
    if s and s.Parent then pcall(function() s:Stop(); s:Play() end) end
end

