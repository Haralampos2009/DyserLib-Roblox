--   Side:AddSlider({ Text = "FOV", Min = 1, Max = 360, Default = 90, Callback = function(v) end })
--   Side:AddInput({ Text = "Name", Default = "", Callback = function(v) end })
--   Side:AddKeybind({ Text = "Macro", Default = Enum.KeyCode.F, Callback = function(v) end })
--   Side:AddColorPicker({ Text = "Color", Default = Color3.fromRGB(255,0,0), Callback = function(c) end })
