-- reference resolution the menu was designed for; scale grows/shrinks
-- proportionally to the actual window size relative to this
local REF_SCREEN = Vector2.new(1920, 1080)

local function autoScaleUI()
    local screenSize = screenGui.AbsoluteSize
    if screenSize.X == 0 or screenSize.Y == 0 then return end

    -- proportional scale based on how big the Roblox window currently is
    local propScale = math.min(screenSize.X / REF_SCREEN.X, screenSize.Y / REF_SCREEN.Y) * MENU_SCALE

    local targetScale = propScale
    local padding = 40

    -- still shrink further if the window gets too small for the menu's min size
    if screenSize.X < (MENU_MIN.X + padding) or screenSize.Y < (MENU_MIN.Y + padding) then
        local scaleX = screenSize.X / (MENU_MIN.X + padding)
        local scaleY = screenSize.Y / (MENU_MIN.Y + padding)
        targetScale = math.min(targetScale, math.min(scaleX, scaleY) * MENU_SCALE)
    end

    uiScale.Scale = math.clamp(targetScale, 0.45, MENU_SCALE)
end
screenGui:GetPropertyChangedSignal("AbsoluteSize"):Connect(autoScaleUI)
task.spawn(autoScaleUI)

