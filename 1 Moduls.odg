    local pg=Instance.new("ScrollingFrame",rightPane)
    pg.Name=name.."Page"; pg.Position=UDim2.fromOffset(0,50); pg.Size=UDim2.new(1,0,1,-50)
    pg.BorderSizePixel=0
    Track.WindowBG(pg)
    pg.ScrollBarThickness=3; Track.Scrollbar(pg)
    pg.CanvasSize=UDim2.fromOffset(0,0); pg.AutomaticCanvasSize=Enum.AutomaticSize.Y; pg.Visible=false
