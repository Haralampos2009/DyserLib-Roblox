tt.lbl.TextColor3 = COLORS.text; tt.lbl.TextXAlignment = Enum.TextXAlignment.Center
tt.lbl.ZIndex = 8889

tt.delay = nil
local function hideTT()
    if tt.delay then task.cancel(tt.delay); tt.delay = nil end
    tt.frame.Visible = false
end
local function addTT(inst, txt)
    if not inst or not txt or txt == "" then return end
    inst.MouseEnter:Connect(function()
        hideTT()
        tt.delay = task.delay(0.6, function()
            local ok,mp = pcall(function() return UserInputService:GetMouseLocation() end)
            if not ok or not inst.Parent then return end
            tt.lbl.Text = txt
            local w = math.clamp(#txt * 6 + 20, 60, 200)
            tt.frame.Size = UDim2.fromOffset(w, 22)
            tt.frame.Position = UDim2.fromOffset(mp.X - w/2, mp.Y - 34)
            tt.frame.Visible = true
            tt.delay = nil
        end)
    end)
    inst.MouseLeave:Connect(hideTT)
    pcall(function() inst.MouseButton1Down:Connect(hideTT) end)
end

