    btn.MouseLeave:Connect(function() TweenService:Create(uiScaleRBtn,TweenInfo.new(.15),{Scale=1}):Play(); if btn ~= Nav.selectedRight then TweenService:Create(btn,TweenInfo.new(.15),{BackgroundColor3=Color3.fromRGB(8,8,9)}):Play() end end)
    
    table.insert(Nav.rightTabBtns,{button=btn,label=lbl4,name=name})
