    local vLbl = label(volRow,"TextLabel",{AnchorPoint=Vector2.new(1,.5), Position=UDim2.new(1,-4,.5,0),Size=UDim2.fromOffset(34,20),Text="50%", TextSize=10,Font=Enum.Font.Code,TextColor3=COLORS.muted, TextXAlignment=Enum.TextXAlignment.Right, Category="Labels"})
        
    local function setVol(a)
        a = math.clamp(a,0,1);
        vFill.Size = UDim2.new(a*.50,0,0,10)
        vLbl.Text = math.floor(a*100).."%"
        uiSoundGroup.Volume = a 
