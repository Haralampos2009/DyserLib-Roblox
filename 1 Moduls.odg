            playsfx("open")
        end
    end)
end
end)()

-- ===================== STARTUP =====================
spawn(function()
    local notif=Instance.new("Frame",screenGui)
    notif.Size=UDim2.fromOffset(250,60); notif.Position=UDim2.new(1,-260,0,20)
    notif.BackgroundColor3=COLORS.panel2; notif.BackgroundTransparency=1; corner(notif,8)
    Track.Stroke(stroke(notif,COLORS.accent,1,0))
    gradient(notif,Color3.fromRGB(20,20,21),Color3.fromRGB(5,5,5),90)
    local tl=Instance.new("Frame",notif); tl.Size=UDim2.new(1,0,0,2); tl.BackgroundColor3=COLORS.accentDk; tl.BorderSizePixel=0
    local nt=label(notif,"TextLabel",{Size=UDim2.new(1,0,1,-8),Text="Loading "..MENU_NAME,TextSize=18,Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Center,TextTransparency=1})
    pad(nt,0,0,2)
    local pbg=Instance.new("Frame",notif); pbg.Size=UDim2.new(1,-10,0,4); pbg.Position=UDim2.fromOffset(5,52); pbg.BackgroundColor3=Color3.fromRGB(30,30,30); pbg.BorderSizePixel=0; corner(pbg,2)
    local pf=Instance.new("Frame",pbg); pf.Size=UDim2.new(1,0,1,0); pf.BackgroundColor3=COLORS.accent; pf.BorderSizePixel=0; corner(pf,2)
    TweenService:Create(notif,TweenInfo.new(.4,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{BackgroundTransparency=0}):Play()
    TweenService:Create(nt,TweenInfo.new(.4,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{TextTransparency=0}):Play()
    TweenService:Create(pf,TweenInfo.new(2.5,Enum.EasingStyle.Linear),{Size=UDim2.new(0,0,1,0)}):Play()
    task.wait(2.5)
    local a=TweenService:Create(notif,TweenInfo.new(.4,Enum.EasingStyle.Back,Enum.EasingDirection.In),{BackgroundTransparency=1,Position=UDim2.new(1,-260,0,-70)})
    TweenService:Create(nt,TweenInfo.new(.4),{TextTransparency=1}):Play(); a:Play(); a.Completed:Wait(); notif:Destroy()
    
    local tgt
    if isMaxed then
        local sz = screenGui.AbsoluteSize
        szLim.MaxSize=Vector2.new(math.huge,math.huge)
        szLim.MinSize=fullMin; body.Visible=true
        tgt = UDim2.fromOffset(sz.X, sz.Y)
    elseif isMin then
        szLim.MinSize=Vector2.new(fullMin.X,30)
        tgt = UDim2.new(fullSize.X.Scale,fullSize.X.Offset,0,30)
    else
        szLim.MinSize=fullMin; body.Visible=true
        tgt = fullSize
    end
    window.Visible=true
    window.Size=UDim2.new(MENU_SIZE.x,0,0,0); window.Position=UDim2.new(MENU_POS.x,0,MENU_POS.y+.1,0)
    TweenService:Create(window,TweenInfo.new(.55,Enum.EasingStyle.Quint,Enum.EasingDirection.Out), {Size=tgt,Position=isMaxed and UDim2.fromOffset(0,0) or UDim2.new(MENU_POS.x,0,MENU_POS.y,0)}):Play()
    playsfx("open")
    AddLog(MENU_NAME.." loaded!", COLORS.accent)

    task.wait(0.9)
    if not screenGui or not screenGui.Parent then return end
    local DS_LINK = "https://discord.gg/wy4BwVb8DC"
    local dn = Instance.new("Frame", screenGui)
    dn.Size = UDim2.fromOffset(268, 70); dn.Position = UDim2.new(1,-278, 1, 20)
    dn.BackgroundColor3 = Color3.fromRGB(30,33,36); dn.BackgroundTransparency = 0; dn.BorderSizePixel = 0; dn.ZIndex = 50
    corner(dn, 10)
    local dnStr = Instance.new("UIStroke", dn); dnStr.Color = Color3.fromRGB(88,101,242); dnStr.Thickness = 1; dnStr.Transparency = 0
    local dnTop = Instance.new("Frame", dn); dnTop.Size = UDim2.new(1,0,0,3); dnTop.BackgroundColor3 = Color3.fromRGB(88,101,242); dnTop.BorderSizePixel = 0; corner(dnTop, 2); dnTop.ZIndex = 51
    local dnIco = Instance.new("TextLabel", dn); dnIco.Position = UDim2.fromOffset(10,10); dnIco.Size = UDim2.fromOffset(30,30); dnIco.BackgroundTransparency = 1; dnIco.Text = "рЯТђ"; dnIco.TextSize = 22; dnIco.Font = Enum.Font.GothamBold; dnIco.ZIndex = 51
    local dnTitle = Instance.new("TextLabel", dn); dnTitle.Position = UDim2.fromOffset(46,8); dnTitle.Size = UDim2.new(1,-68,0,18); dnTitle.BackgroundTransparency = 1; dnTitle.Text = "Join our Discord!"; dnTitle.TextSize = 12; dnTitle.Font = Enum.Font.GothamBold; dnTitle.TextColor3 = Color3.fromRGB(255,255,255); dnTitle.TextXAlignment = Enum.TextXAlignment.Left; dnTitle.ZIndex = 51
    local dnUrl = Instance.new("TextLabel", dn); dnUrl.Position = UDim2.fromOffset(46,26); dnUrl.Size = UDim2.new(1,-68,0,14); dnUrl.BackgroundTransparency = 1; dnUrl.Text = "discord.gg/wy4BwVb8DC"; dnUrl.TextSize = 10; dnUrl.Font = Enum.Font.Code; dnUrl.TextColor3 = Color3.fromRGB(88,101,242); dnUrl.TextXAlignment = Enum.TextXAlignment.Left; dnUrl.ZIndex = 51
    local dnJoin = Instance.new("TextButton", dn); dnJoin.Position = UDim2.fromOffset(46,44); dnJoin.Size = UDim2.fromOffset(56,20); dnJoin.BackgroundColor3 = Color3.fromRGB(88,101,242); dnJoin.BorderSizePixel = 0; dnJoin.Text = "Join"; dnJoin.TextSize = 11; dnJoin.Font = Enum.Font.GothamBold; dnJoin.TextColor3 = Color3.fromRGB(255,255,255); dnJoin.AutoButtonColor = false; dnJoin.ZIndex = 52; corner(dnJoin, 4)
    local dnX = Instance.new("TextButton", dn); dnX.AnchorPoint = Vector2.new(1,0); dnX.Position = UDim2.new(1,-5,0,5); dnX.Size = UDim2.fromOffset(18,18); dnX.BackgroundTransparency = 1; dnX.Text = "вЬХ"; dnX.TextSize = 11; dnX.Font = Enum.Font.GothamBold; dnX.TextColor3 = Color3.fromRGB(140,140,145); dnX.AutoButtonColor = false; dnX.ZIndex = 52
    
    local function closeDn()
        TweenService:Create(dn, TweenInfo.new(.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position=UDim2.new(1,-278,1,20)}):Play()
        task.delay(.25, function() if dn and dn.Parent then dn:Destroy() end end)
    end
    dnJoin.MouseEnter:Connect(function() TweenService:Create(dnJoin,TweenInfo.new(.1),{BackgroundColor3=Color3.fromRGB(110,125,255)}):Play() end)
    dnJoin.MouseLeave:Connect(function() TweenService:Create(dnJoin,TweenInfo.new(.1),{BackgroundColor3=Color3.fromRGB(88,101,242)}):Play() end)
    dnJoin.MouseButton1Click:Connect(function()
        if setclipboard then setclipboard(DS_LINK) end
        dnJoin.Text = "Copied!"; dnJoin.BackgroundColor3 = Color3.fromRGB(46,204,113)
        task.delay(2, function() if dnJoin and dnJoin.Parent then dnJoin.Text="Join"; dnJoin.BackgroundColor3=Color3.fromRGB(88,101,242) end end)
    end)
    dnX.MouseButton1Click:Connect(closeDn)
    TweenService:Create(dn, TweenInfo.new(.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position=UDim2.new(1,-278, 1,-80)}):Play()
    task.delay(8, function() if dn and dn.Parent then closeDn() end end)
end)


-- ===================== PUBLIC API =====================
-- –≠—В–Њ –њ—Г–±–ї–Є—З–љ—Л–є –Є–љ—В–µ—А—Д–µ–є—Б –±–Є–±–ї–Є–Њ—В–µ–Ї–Є вАФ –≤–Њ–Ј–≤—А–∞—Й–∞–µ—В—Б—П –љ–∞—А—Г–ґ—Г —З–µ—А–µ–Ј loadstring(...)()
-- –Я—А–Є–Љ–µ—А –Є—Б–њ–Њ–ї—М–Ј–Њ–≤–∞–љ–Є—П:
--   local Dyser = loadstring(game:HttpGet(URL))()
--   local Win   = Dyser:GetWindow()
--   local Tab   = Win:AddTopTab("Combat")
--   local Side  = Tab:AddSideTab("Aimbot")
