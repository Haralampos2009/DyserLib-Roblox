local function cursorHover(state)
    cur.hovering = state
    if cur.clickAnim then return end
    if state then
        TweenService:Create(cur.ring,TweenInfo.new(.15, Enum.EasingStyle.Sine),{Size=UDim2.fromOffset(28,28)}):Play()
        TweenService:Create(cur.stroke,TweenInfo.new(.15, Enum.EasingStyle.Sine),{Transparency=.5}):Play()
    else
        TweenService:Create(cur.ring,TweenInfo.new(.15, Enum.EasingStyle.Sine),{Size=UDim2.fromOffset(22,22)}):Play()
        TweenService:Create(cur.stroke,TweenInfo.new(.15, Enum.EasingStyle.Sine),{Transparency=0}):Play()
    end
end

local function bindCursorHover(obj)
    obj.MouseEnter:Connect(function() 
        cursorHover(true)
        playsfx("hover")
    end)
    obj.MouseLeave:Connect(function() 
        cursorHover(false) 
    end)
    if obj:IsA("TextBox") then
        obj.Focused:Connect(function() 
            cursorHover(true)
            playsfx("click")
        end)
        obj.FocusLost:Connect(function() cursorHover(false) end)
    end
end

local function cursorPulse()
    if cur.clickAnim then return end
    cur.clickAnim = true
    TweenService:Create(cur.ring,TweenInfo.new(.08),{Size=UDim2.fromOffset(30,30)}):Play()
    TweenService:Create(cur.glow,TweenInfo.new(.08),{BackgroundTransparency=.55}):Play()
    TweenService:Create(cur.dot, TweenInfo.new(.08),{Size=UDim2.fromOffset(7,7)}):Play()
    task.delay(.08,function()
        local targetRingSize = cur.hovering and 28 or 22
        TweenService:Create(cur.ring,TweenInfo.new(.2,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Size=UDim2.fromOffset(targetRingSize,targetRingSize)}):Play()
        TweenService:Create(cur.glow,TweenInfo.new(.2),{BackgroundTransparency=.8}):Play()
        TweenService:Create(cur.dot, TweenInfo.new(.2,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Size=UDim2.fromOffset(4,4)}):Play()
        cur.clickAnim = false
    end)
end

table.insert(scriptConnections, RunService.RenderStepped:Connect(function(dt)
    if UserInputService.TouchEnabled and not UserInputService.MouseEnabled then
        if cur.inside then
            cur.inside = false
            cur.frame.Visible = false
            UserInputService.MouseIconEnabled = true
        end
        return
    end

    if not cur.enabled then return end
    if not screenGui.Enabled then
        if cur.inside then
            cur.inside = false
            cur.frame.Visible = false
            UserInputService.MouseIconEnabled = true
        end
        return
    end

    local ok,mp = pcall(function() return UserInputService:GetMouseLocation() end)
    if not ok then return end
    local inset = game:GetService("GuiService"):GetGuiInset()
    local wx = window.AbsolutePosition.X
    local wy = window.AbsolutePosition.Y + inset.Y
    local ww = window.AbsoluteSize.X
    local wh = window.AbsoluteSize.Y
    local activeH = isMin and SIZES.topBar or wh
    
    local inside = window.Visible and screenGui.Enabled
        and mp.X >= wx and mp.X <= wx+ww
        and mp.Y >= wy and mp.Y <= wy+activeH

    if inside then
        cur.frame.Position = UDim2.fromOffset(mp.X, mp.Y)
        if not cur.frame.Visible then cur.frame.Visible = true end
        if not cur.inside then
            cur.inside = true
            UserInputService.MouseIconEnabled = false
        end
        if cur.spinEnabled then
            cur.angle = (cur.angle + cur.spinSpeed * dt) % 360
            cur.ring.Rotation = cur.angle
            cur.ch.Rotation  = cur.angle
            cur.cv.Rotation  = cur.angle
        end
        if cur.rainbow then
            cur.rainbowHue = (cur.rainbowHue + dt * cur.rainbowSpeed) % 1
            local c = Color3.fromHSV(cur.rainbowHue, 1, 1)
            cur.glow.BackgroundColor3 = c
            cur.dot.BackgroundColor3  = c
            cur.ch.BackgroundColor3   = c
            cur.cv.BackgroundColor3   = c
            cur.stroke.Color          = c
        end
    else
        if cur.inside then
            cur.inside = false
            cur.frame.Visible = false
            UserInputService.MouseIconEnabled = true
        end
    end
end))

table.insert(scriptConnections, RunService.RenderStepped:Connect(function(dt)
    if not ui.rainbow then return end
    ui.rainbowHue = (ui.rainbowHue + dt * ui.rainbowSpeed) % 1
    setAccent(Color3.fromHSV(ui.rainbowHue, 1, 1))
end))

