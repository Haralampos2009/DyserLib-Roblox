-- ===================== ROW BUILDER =====================
local function rowLine(p)
    local l=Instance.new("Frame",p); l.AnchorPoint=Vector2.new(0,1); l.Position=UDim2.new(0,0,1,0); l.Size=UDim2.new(1,0,0,1); l.BackgroundColor3=Color3.fromRGB(28,28,30); l.BorderSizePixel=0
end

local function makeRow(h)
    local r=Instance.new("Frame",settingsPage)
    r.Size=UDim2.new(1,0,0,h or 28); Track.WindowBG(r); r.BackgroundTransparency=.04; r.BorderSizePixel=0; r.Active=true
    table.insert(Elems.row, r)
    rowLine(r)
    if curSection then table.insert(curSection.rows,r) end
    return r
end

local function rowLabel(row,txt, category)
    local l=label(row,"TextLabel",{Name="Label",Size=UDim2.new(1,-32,1,0),Text=txt or "Option", TextSize=TSIZES.label,TextColor3=Color3.fromRGB(205,205,210), Category = category or "Labels"})
    l.TextStrokeTransparency=.75; pad(l,3); return l
end

local function addSection(txt,tabName)
    local sec=Instance.new("Frame",settingsPage)
    sec.Size=UDim2.new(1,0,0,SIZES.sectionH); Track.WindowBG(sec); sec.BorderSizePixel=0
    table.insert(Elems.section, sec)
    local top=Instance.new("Frame",sec); top.Position=UDim2.fromOffset(0,4); top.Size=UDim2.new(1,0,0,2); top.BorderSizePixel=0; Track.DkBG(top)
    local bot=Instance.new("Frame",sec); bot.AnchorPoint=Vector2.new(0,1); bot.Position=UDim2.new(0,0,1,0); bot.Size=UDim2.new(1,0,0,1); bot.BackgroundColor3=Color3.fromRGB(30,30,32); bot.BorderSizePixel=0
    local l=label(sec,"TextLabel",{Position=UDim2.fromOffset(0,4),Size=UDim2.new(1,-28,0,21),Text=txt or "Section",TextSize=TSIZES.section, Category="Labels"}); pad(l,3)
    local collapsed=false
    local arr=label(sec,"TextButton",{AnchorPoint=Vector2.new(1,0),Position=UDim2.new(1,-3,0,7), Size=UDim2.fromOffset(16,16),BackgroundTransparency=0,BackgroundColor3=Color3.fromRGB(8,8,9), Text="^",TextSize=10,Font=Enum.Font.GothamBold,AutoButtonColor=false, Category="Buttons"})
    corner(arr,3); stroke(arr,COLORS.line,1,.15); bindCursorHover(arr)
    local grp={rows={},name=tabName}; curSection=grp
    arr.MouseButton1Click:Connect(function() playsfx("click"); collapsed=not collapsed; arr.Text=collapsed and ">" or "^"; for _,r in ipairs(grp.rows) do if r and r.Parent then r.Visible=not collapsed end end end)
end

local function addToggle(txt,cb)
    local row=makeRow(23); rowLabel(row,txt, "Labels")
    if curSection then regSearch(txt,curSection.name,row) end
    local en=false
    local box=label(row,"TextButton",{AnchorPoint=Vector2.new(1,.5),Position=UDim2.new(1,-3,.5,0), Size=UDim2.fromOffset(SIZES.toggleBox,SIZES.toggleBox),BackgroundTransparency=0, BackgroundColor3=Color3.fromRGB(16,10,15),Text="x",TextColor3=COLORS.pink, TextSize=18,Font=FONTS.bold,AutoButtonColor=false, Category="Buttons"})
    box.TextStrokeTransparency=.25; corner(box,4); bindCursorHover(box)
    local inactStr=stroke(box,Color3.fromRGB(48,28,43),1,.05)
    local glowStr=stroke(box,COLORS.accent,2,.0); glowStr.Transparency=1; table.insert(Acc.strokes,glowStr)
    local function set(v, _silent)
        local prevVal = en
        en=v; menuState.toggles[txt]=v
        box.Text=v and "вЬУ" or "x"
        box.TextColor3=v and Color3.fromRGB(70,230,120) or COLORS.pink
        box.BackgroundColor3=v and Color3.fromRGB(9,30,15) or Color3.fromRGB(16,10,15)
        row.BackgroundTransparency=v and .02 or .14
        TweenService:Create(glowStr,TweenInfo.new(.2),{Transparency=v and .1 or 1}):Play()
        inactStr.Transparency = v and 1 or .05
        if not _silent and addHistoryEntry then
            playsfx(v and "toggleOn" or "toggleOff")
            addHistoryEntry((v and "вЬУ ON  " or "вЬЧ OFF ")..txt, v and COLORS.accent or COLORS.pink, function() set(prevVal, true) end)
        end
        if cb then cb(v) end
    end
    row.MouseEnter:Connect(function() TweenService:Create(row,TweenInfo.new(.12),{BackgroundTransparency=0}):Play() end)
    row.MouseLeave:Connect(function() TweenService:Create(row,TweenInfo.new(.12),{BackgroundTransparency=en and .02 or .14}):Play() end)
    toggleSet[txt]=function(v) set(v, true) end
    set(false, true)
    table.insert(scriptConnections,box.MouseButton1Click:Connect(function() set(not en) end))
end

local function addButton(txt,cb)
    local row=makeRow(23)
    if curSection then regSearch(txt,curSection.name,row) end
    local btn=label(row,"TextButton",{Size=UDim2.new(1,-12,1,-4),Position=UDim2.fromOffset(6,2),Text="", TextSize=TSIZES.label,BackgroundTransparency=0,BackgroundColor3=COLORS.accent, Font=FONTS.bold,AutoButtonColor=false, Category="Buttons"})
    corner(btn,4); Track.BG(btn); bubble(btn,20,true,nil,nil,true); bindCursorHover(btn)
    local l2=label(btn,"TextLabel",{Size=UDim2.new(1,0,1,0),Text=txt,TextSize=TSIZES.label, Font=FONTS.bold,TextXAlignment=Enum.TextXAlignment.Center, Category="Buttons"}); l2.ZIndex=10
    local btnSc=Instance.new("UIScale",btn); btnSc.Scale=1
    btn.MouseEnter:Connect(function() TweenService:Create(btn,TweenInfo.new(.12),{BackgroundColor3=scaledC(COLORS.accent,1.15)}):Play(); TweenService:Create(btnSc,TweenInfo.new(.12),{Scale=1.03}):Play() end)
    btn.MouseLeave:Connect(function() TweenService:Create(btn,TweenInfo.new(.12),{BackgroundColor3=COLORS.accent}):Play(); TweenService:Create(btnSc,TweenInfo.new(.12),{Scale=1}):Play() end)
    table.insert(scriptConnections,btn.MouseButton1Click:Connect(function()
        playsfx("click"); TweenService:Create(btn,TweenInfo.new(.08),{BackgroundColor3=COLORS.accentDk}):Play()
        task.delay(.08,function() if btn.Parent then TweenService:Create(btn,TweenInfo.new(.12),{BackgroundColor3=COLORS.accent}):Play() end end)
        if addHistoryEntry then addHistoryEntry("рЯФШ "..txt, COLORS.accent) end
        if cb then cb() else AddLog("Clicked: "..txt,COLORS.accent) end
    end))
end

local function addSlider(txt,val,fillScale,cb)
    local row=makeRow(23)
    if curSection then regSearch(txt,curSection.name,row) end
    local track=Instance.new("Frame",row); track.Position=UDim2.fromOffset(0,3); track.Size=UDim2.new(1,-2,0,SIZES.sliderH); track.BackgroundColor3=Color3.fromRGB(10,10,11); track.BorderSizePixel=0; track.Active=true; stroke(track,Color3.fromRGB(28,28,30),1,.15); bindCursorHover(track)
    local fill=Instance.new("Frame",row); fill.Position=UDim2.fromOffset(0,3); fill.Size=UDim2.new(fillScale or .5,0,0,SIZES.sliderH); fill.BackgroundColor3=COLORS.accent; fill.BorderSizePixel=0; fill.Active=true; Track.Grad(gradient(fill,COLORS.accentDk,COLORS.accent,0)); bubble(fill,20,false,nil,nil,true)
    rowLabel(row,txt, "Sliders")
    local vt=label(row,"TextLabel",{AnchorPoint=Vector2.new(1,0),Position=UDim2.new(1,-5,0,0), Size=UDim2.fromOffset(72,23),Text=tostring(val or 50),TextSize=TSIZES.value,TextXAlignment=Enum.TextXAlignment.Right, Category="Sliders"})
    local maxN=(tonumber(tostring(val)) or 100)/(fillScale or .5)
    local function setA(a)
        a=math.clamp(a,0,1); fill.Size=UDim2.new(a,0,0,SIZES.sliderH)
        vt.Text=tostring(math.floor(maxN*a+.5)); menuState.sliders[txt]=a
        if cb then cb(a) end
    end
    local function fromX(x) setA((x-track.AbsolutePosition.X)/track.AbsoluteSize.X) end
    sliderSet[txt]=setA; menuState.sliders[txt]=fillScale or .5
    row.MouseEnter:Connect(function() TweenService:Create(track,TweenInfo.new(.12),{BackgroundColor3=Color3.fromRGB(18,18,20)}):Play() end)
    row.MouseLeave:Connect(function() TweenService:Create(track,TweenInfo.new(.12),{BackgroundColor3=Color3.fromRGB(10,10,11)}):Play() end)
    local dragging = false; local sf = nil; local prevVal = menuState.sliders[txt] or (fillScale or .5)
    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; prevVal = menuState.sliders[txt] or (fillScale or .5); sf = row.Parent
            if sf and sf:IsA("ScrollingFrame") then sf.ScrollingEnabled = false end
            fromX(input.Position.X)
        end
    end)
    UserInputService.InputChanged:Connect(function(input) if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then fromX(input.Position.X) end end)
    UserInputService.InputEnded:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false; if sf and sf:IsA("ScrollingFrame") then sf.ScrollingEnabled = true end
            playsfx("slider")
            if addHistoryEntry then
                local snapVal = prevVal
                addHistoryEntry("вЯЈ "..txt.." вЖТ "..vt.Text, COLORS.muted, function() setA(snapVal) end)
            end
        end
    end)
end

local function addInput(txt,def,cb)
    local row=makeRow(28)
    if curSection then regSearch(txt,curSection.name,row) end
    rowLabel(row,txt, "Inputs")
    local box=Instance.new("TextBox",row)
    box.AnchorPoint=Vector2.new(1,.5); box.Position=UDim2.new(1,-4,.5,0); box.Size=UDim2.fromOffset(120,20); box.BackgroundColor3=Color3.fromRGB(15,15,16)
    box.BorderSizePixel=0; box.Text=def or ""; box.PlaceholderText="..."
    box.PlaceholderColor3=COLORS.muted; box.TextColor3=COLORS.text; box.TextSize=11
    box.Font=Enum.Font.Code; box.ClearTextOnFocus=false
    corner(box,3); stroke(box,Color3.fromRGB(30,30,32),1,.2); pad(box,5); bindCursorHover(box); trackText("Inputs", box); trackColorText(box)
    local prevText = def or ""
    table.insert(scriptConnections,box.FocusLost:Connect(function() 
        if box.Text ~= prevText then
            local oldTxt = prevText; local newTxt = box.Text; prevText = newTxt
            if cb then cb(newTxt) end
            if addHistoryEntry then
                addHistoryEntry("вМ® " .. txt .. " вЖТ " .. newTxt, COLORS.text, function() box.Text = oldTxt; prevText = oldTxt; if cb then cb(oldTxt) end end)
            end
        end
    end))
    return box
end

-- Configurable keybind row: shows a "rebind" button (click then press a key)
-- and an ON/OFF toggle box. defaultKey is an Enum.KeyCode; onToggle(active)
-- fires whenever the bound key is pressed and the bind is enabled, or when
-- the toggle box itself is clicked directly.
local function addKeybind(txt, defaultKey, onToggle)
    local row=makeRow(23)
    if curSection then regSearch(txt,curSection.name,row) end
    rowLabel(row,txt, "Labels")

    local active=false
    local keyCode=defaultKey

    local toggleBox=label(row,"TextButton",{AnchorPoint=Vector2.new(1,.5),Position=UDim2.new(1,-3,.5,0), Size=UDim2.fromOffset(SIZES.toggleBox,SIZES.toggleBox),BackgroundTransparency=0, BackgroundColor3=Color3.fromRGB(16,10,15),Text="x",TextColor3=COLORS.pink, TextSize=18,Font=FONTS.bold,AutoButtonColor=false, Category="Buttons"})
    toggleBox.TextStrokeTransparency=.25; corner(toggleBox,4); bindCursorHover(toggleBox)
    local inactStr=stroke(toggleBox,Color3.fromRGB(48,28,43),1,.05)
    local glowStr=stroke(toggleBox,COLORS.accent,2,.0); glowStr.Transparency=1; table.insert(Acc.strokes,glowStr)

    local keyBtn=label(row,"TextButton",{AnchorPoint=Vector2.new(1,.5),Position=UDim2.new(1,-3-SIZES.toggleBox-6,.5,0), Size=UDim2.fromOffset(64,20),BackgroundColor3=Color3.fromRGB(15,15,16), Text=keyCode and keyCode.Name or "None",TextColor3=COLORS.text,TextSize=11,Font=Enum.Font.Code,AutoButtonColor=false, Category="Inputs"})
    corner(keyBtn,3); stroke(keyBtn,Color3.fromRGB(30,30,32),1,.2); bindCursorHover(keyBtn); trackText("Inputs", keyBtn); trackColorText(keyBtn)

    local entry = {keyCode=keyCode, button=keyBtn, active=false}

    local function setActive(v)
        local prevVal = active
        active=v; entry.active=v
        toggleBox.Text=v and "вЬУ" or "x"
        toggleBox.TextColor3=v and Color3.fromRGB(70,230,120) or COLORS.pink
        toggleBox.BackgroundColor3=v and Color3.fromRGB(9,30,15) or Color3.fromRGB(16,10,15)
        row.BackgroundTransparency=v and .02 or .14
        TweenService:Create(glowStr,TweenInfo.new(.2),{Transparency=v and .1 or 1}):Play()
        inactStr.Transparency = v and 1 or .05
        if addHistoryEntry then
            playsfx(v and "toggleOn" or "toggleOff")
            addHistoryEntry((v and "вЬУ ON  " or "вЬЧ OFF ")..txt, v and COLORS.accent or COLORS.pink, function() setActive(prevVal) end)
        end
        if onToggle then onToggle(v) end
    end
    entry.setActive = setActive

    row.MouseEnter:Connect(function() TweenService:Create(row,TweenInfo.new(.12),{BackgroundTransparency=0}):Play() end)
    row.MouseLeave:Connect(function() TweenService:Create(row,TweenInfo.new(.12),{BackgroundTransparency=active and .02 or .14}):Play() end)
    table.insert(scriptConnections,toggleBox.MouseButton1Click:Connect(function() setActive(not active) end))

    table.insert(scriptConnections,keyBtn.MouseButton1Click:Connect(function()
        playsfx("click")
        keyBtn.Text="..."
        waitingBind=entry
    end))

    table.insert(keybinds, entry)
    return entry
end

-- Simple "rebind only" row (no on/off checkbox) вАФ used for things like the
-- menu open/close hotkey, where there's nothing to enable/disable, just a key.
local function addRebindOnly(txt, currentKey, onRebind)
    local row=makeRow(23)
    if curSection then regSearch(txt,curSection.name,row) end
    rowLabel(row,txt, "Labels")

    local keyBtn=label(row,"TextButton",{AnchorPoint=Vector2.new(1,.5),Position=UDim2.new(1,-3,.5,0), Size=UDim2.fromOffset(80,20),BackgroundColor3=Color3.fromRGB(15,15,16), Text=currentKey and currentKey.Name or "None",TextColor3=COLORS.text,TextSize=11,Font=Enum.Font.Code,AutoButtonColor=false, Category="Inputs"})
    corner(keyBtn,3); stroke(keyBtn,Color3.fromRGB(30,30,32),1,.2); bindCursorHover(keyBtn); trackText("Inputs", keyBtn); trackColorText(keyBtn)

    local entry = {keyCode=currentKey, button=keyBtn, isRebindOnly=true}
    entry.setKey = function(kc)
        entry.keyCode = kc
        keyBtn.Text = kc and kc.Name or "None"
        if onRebind then onRebind(kc) end
    end

    table.insert(scriptConnections,keyBtn.MouseButton1Click:Connect(function()
        playsfx("click")
        keyBtn.Text="..."
        waitingBind=entry
    end))

    table.insert(keybinds, entry)
    return entry
end



local function addColorPicker(txt, defaultCol, cb)
    local collapsedHeight = 28
    local expandedHeight = 230
    local row = makeRow(collapsedHeight)
    row.ClipsDescendants = true
    
    local lbl = rowLabel(row, txt, "Palettes")
    lbl.Size = UDim2.new(1, -32, 0, collapsedHeight)
    lbl.TextYAlignment = Enum.TextYAlignment.Center

    if curSection then regSearch(txt, curSection.name, row) end
    
    local previewBtn = Instance.new("TextButton", row)
    previewBtn.Size = UDim2.fromOffset(20, 20)
    previewBtn.Position = UDim2.new(1, -26, 0, 4)
    previewBtn.BackgroundColor3 = defaultCol
    previewBtn.Text = ""
    previewBtn.AutoButtonColor = false
    corner(previewBtn, 4)
    stroke(previewBtn, COLORS.lineLight, 1, 0)
    bindCursorHover(previewBtn)

    local curH, curS, curV = defaultCol:ToHSV()
    local expanded = false

    local bodyCont = Instance.new("Frame", row)
    bodyCont.Size = UDim2.new(1, 0, 0, expandedHeight - collapsedHeight)
    bodyCont.Position = UDim2.new(0, 0, 0, collapsedHeight)
    bodyCont.BackgroundTransparency = 1
    bodyCont.Visible = false

    local colorBox = Instance.new("TextButton", bodyCont)
    colorBox.Size = UDim2.new(1, -45, 0, 150)
    colorBox.Position = UDim2.new(0, 10, 0, 10)
    colorBox.AutoButtonColor = false
    colorBox.Text = ""
    corner(colorBox, 4)
    stroke(colorBox, COLORS.lineLight, 1, 0)

    local satFrame = Instance.new("Frame", colorBox)
    satFrame.Size = UDim2.new(1, 0, 1, 0)
    satFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    satFrame.BorderSizePixel = 0
    corner(satFrame, 4)
    local satGrad = Instance.new("UIGradient", satFrame)
    satGrad.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1)})
    
    local valFrame = Instance.new("Frame", colorBox)
    valFrame.Size = UDim2.new(1, 0, 1, 0)
    valFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    valFrame.BorderSizePixel = 0
    corner(valFrame, 4)
    local valGrad = Instance.new("UIGradient", valFrame)
    valGrad.Rotation = -90
    valGrad.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1)})

    local colorThumb = Instance.new("Frame", colorBox)
    colorThumb.Size = UDim2.fromOffset(10, 10)
    colorThumb.AnchorPoint = Vector2.new(0.5, 0.5)
    colorThumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    corner(colorThumb, 10)
    stroke(colorThumb, Color3.fromRGB(0,0,0), 1, 0.2)

    local hueSlider = Instance.new("TextButton", bodyCont)
    hueSlider.Size = UDim2.new(0, 16, 0, 150)
    hueSlider.Position = UDim2.new(1, -26, 0, 10)
    hueSlider.AutoButtonColor = false
    hueSlider.Text = ""
    corner(hueSlider, 4)
    stroke(hueSlider, COLORS.lineLight, 1, 0)

    local hueGrad = Instance.new("UIGradient", hueSlider)
    hueGrad.Rotation = 90
    hueGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
        ColorSequenceKeypoint.new(0.167, Color3.fromRGB(255, 0, 255)),
        ColorSequenceKeypoint.new(0.333, Color3.fromRGB(0, 0, 255)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
        ColorSequenceKeypoint.new(0.667, Color3.fromRGB(0, 255, 0)),
        ColorSequenceKeypoint.new(0.833, Color3.fromRGB(255, 255, 0)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0))
    })

    local hueThumb = Instance.new("Frame", hueSlider)
    hueThumb.Size = UDim2.new(1, 4, 0, 6)
    hueThumb.Position = UDim2.new(0, -2, 0, 0)
    hueThumb.AnchorPoint = Vector2.new(0, 0.5)
    hueThumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    corner(hueThumb, 2)
    stroke(hueThumb, Color3.fromRGB(0,0,0), 1, 0.5)

    local hexInput = Instance.new("TextBox", bodyCont)
    hexInput.Size = UDim2.new(0.5, -15, 0, 24)
    hexInput.Position = UDim2.new(0, 10, 0, 170)
    hexInput.BackgroundColor3 = Color3.fromRGB(15, 15, 16)
    hexInput.TextColor3 = COLORS.text
    hexInput.Font = Enum.Font.Code
    hexInput.TextSize = 11
    hexInput.ClearTextOnFocus = false
    corner(hexInput, 4)
    stroke(hexInput, COLORS.line, 1, 0.2)
    bindCursorHover(hexInput)
    trackText("Palettes", hexInput)
    trackColorText(hexInput)

    local rgbInput = Instance.new("TextBox", bodyCont)
    rgbInput.Size = UDim2.new(0.5, -15, 0, 24)
    rgbInput.Position = UDim2.new(0.5, 5, 0, 170)
    rgbInput.BackgroundColor3 = Color3.fromRGB(15, 15, 16)
    rgbInput.TextColor3 = COLORS.text
    rgbInput.Font = Enum.Font.Code
    rgbInput.TextSize = 11
    rgbInput.ClearTextOnFocus = false
    corner(rgbInput, 4)
    stroke(rgbInput, COLORS.line, 1, 0.2)
    bindCursorHover(rgbInput)
    trackText("Palettes", rgbInput)
    trackColorText(rgbInput)

    local function updateUI()
        colorBox.BackgroundColor3 = Color3.fromHSV(curH, 1, 1)
        colorThumb.Position = UDim2.new(curS, 0, 1 - curV, 0)
        hueThumb.Position = UDim2.new(0, -2, 1 - curH, 0)

        local fin = Color3.fromHSV(curH, curS, curV)
        previewBtn.BackgroundColor3 = fin
        local r, g, b = math.round(fin.R * 255), math.round(fin.G * 255), math.round(fin.B * 255)
        
        if not hexInput:IsFocused() then hexInput.Text = string.format("#%02X%02X%02X", r, g, b) end
        if not rgbInput:IsFocused() then rgbInput.Text = string.format("%d, %d, %d", r, g, b) end

        if cb then cb(fin) end
    end

    local draggingColor, draggingHue = false, false
    local dragStartH, dragStartS, dragStartV = curH, curS, curV

    local function setCol(input)
        local rx = math.clamp(input.Position.X - colorBox.AbsolutePosition.X, 0, colorBox.AbsoluteSize.X)
        local ry = math.clamp(input.Position.Y - colorBox.AbsolutePosition.Y, 0, colorBox.AbsoluteSize.Y)
        curS = rx / colorBox.AbsoluteSize.X
        curV = 1 - (ry / colorBox.AbsoluteSize.Y)
        updateUI()
    end

    local function setHue(input)
        local ry = math.clamp(input.Position.Y - hueSlider.AbsolutePosition.Y, 0, hueSlider.AbsoluteSize.Y)
        curH = 1 - (ry / hueSlider.AbsoluteSize.Y)
        updateUI()
    end

    colorBox.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingColor = true
            dragStartH, dragStartS, dragStartV = curH, curS, curV 
            local sf = row.Parent
            if sf and sf:IsA("ScrollingFrame") then sf.ScrollingEnabled = false end
            setCol(i)
        end
    end)
    
    hueSlider.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingHue = true
            dragStartH, dragStartS, dragStartV = curH, curS, curV 
            local sf = row.Parent
            if sf and sf:IsA("ScrollingFrame") then sf.ScrollingEnabled = false end
            setHue(i)
        end
    end)

    UserInputService.InputChanged:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseMovement then
            if draggingColor then setCol(i)
            elseif draggingHue then setHue(i) end
        end
    end)

    UserInputService.InputEnded:Connect(function(i)
         if i.UserInputType == Enum.UserInputType.MouseButton1 then
            if draggingColor or draggingHue then
                draggingColor = false
                draggingHue = false
                local sf = row.Parent
                if sf and sf:IsA("ScrollingFrame") then sf.ScrollingEnabled = true end
                
                if addHistoryEntry then 
                    local snapH, snapS, snapV = dragStartH, dragStartS, dragStartV
                    addHistoryEntry("рЯО® Changed color: " .. txt, previewBtn.BackgroundColor3, function()
                        curH, curS, curV = snapH, snapS, snapV
                        updateUI()
                    end)
                end
            end
        end
    end)

    hexInput:GetPropertyChangedSignal("Text"):Connect(function()
        if not hexInput:IsFocused() then return end
        local t = hexInput.Text:gsub("#", "")
        if #t == 6 then
            local r, g, b = tonumber(t:sub(1,2), 16), tonumber(t:sub(3,4), 16), tonumber(t:sub(5,6), 16)
            if r and g and b then curH, curS, curV = Color3.fromRGB(r, g, b):ToHSV(); updateUI() end
        end
    end)

    rgbInput:GetPropertyChangedSignal("Text"):Connect(function()
        if not rgbInput:IsFocused() then return end
        local parts = rgbInput.Text:split(",")
        if #parts == 3 then
            local r = tonumber(parts[1]:match("%d+")); local g = tonumber(parts[2]:match("%d+")); local b = tonumber(parts[3]:match("%d+"))
            if r and g and b and r <= 255 and g <= 255 and b <= 255 then curH, curS, curV = Color3.fromRGB(r, g, b):ToHSV(); updateUI() end
        end
    end)

    hexInput.FocusLost:Connect(function(enter)
        if enter then
            local t = hexInput.Text:gsub("#", "")
            if #t == 6 then
                local r, g, b = tonumber(t:sub(1,2), 16), tonumber(t:sub(3,4), 16), tonumber(t:sub(5,6), 16)
                if r and g and b then
                    local oldH, oldS, oldV = curH, curS, curV 
                    curH, curS, curV = Color3.fromRGB(r, g, b):ToHSV()
                    updateUI()
                    if addHistoryEntry then 
                        addHistoryEntry("рЯО® Hex Changed: " .. txt, previewBtn.BackgroundColor3, function()
                            curH, curS, curV = oldH, oldS, oldV
                            updateUI()
                         end) 
                    end
                end
            end
        end
        updateUI()
    end)

    previewBtn.MouseButton1Click:Connect(function()
        expanded = not expanded
        if expanded then bodyCont.Visible = true end 
        local tw = TweenService:Create(row, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 0, expanded and expandedHeight or collapsedHeight)})
        tw:Play()
        if not expanded then task.delay(0.25, function() if not expanded then bodyCont.Visible = false end end) end
        playsfx("click")
    end)

    updateUI()
end

-- ===================== TAB CONTENT =====================
local TAB_CONTENT = {
    Settings = {
        {"section", "Hotkeys"},
        {"rebind", "Open / Close Menu", TOGGLE_KEY, function(kc)
            TOGGLE_KEY = kc
        end},
    },
    Themes = {
        {"section", "UI Styling"},
        {"button", "Bubble Theme", function() setBubbles(true) end},
        {"button", "Solid Theme", function() setBubbles(false) end},
        
        {"section", "Colors"},
        {"colorpicker", "Accent Color (Buttons, etc.)", COLORS.accent, function(c)
            ui.savedAccentColor = c
            if not ui.rainbow then setAccent(c) end
        end},
        {"colorpicker", "Text Color (Global)", COLORS.text, function(c) setTextColor(c) end},
        {"colorpicker", "Window Background", COLORS.windowBg, function(c) setWindowBackground(c) end},
        {"colorpicker", "Panel Color", COLORS.panel, function(c) setPanel(c) end},
        {"colorpicker", "Panel2 Color", COLORS.panel2, function(c) setPanel2(c) end},
        {"colorpicker", "Scrollbar Color", COLORS.scrollbar, function(c) setScrollbarColor(c) end},

        {"section", "Open / Close Effect"},
        {"colorpicker", "Effect Glow Color", ui.glowColor, function(c) ui.glowColor = c end},

        {"section", "Rainbow"},
        {"toggle", "Rainbow Accent (Dyser title, buttons, etc.)", function(v)
            ui.rainbow = v
            if not v then
                setAccent(ui.savedAccentColor or COLORS.accent)
            end
        end},
        {"slider", "Rainbow Speed", 40, 0.4, function(a) ui.rainbowSpeed = a * 2.0 end},

        {"section", "Transparency"},
        {"slider", "Window BG", 0, 0, function(a) setWindowTransparency(a) end},
        {"slider", "TopBar", 0, 0, function(a) setPanel2Transparency(a) end},
        {"slider", "Side Panel", 0, 0, function(a) setPanelTransparency(a) end},
        
        {"section", "Tab Scaling"},
        {"slider", "Top Tabs Size", 50, 0.5, function(a) updateTextSize("TopTabs", math.floor(8 + a * 16)) end},
        {"slider", "Side Tabs Size", 50, 0.5, function(a) updateTextSize("SideTabs", math.floor(8 + a * 16)) end},
        
        {"section", "Element Scaling"},
        {"slider", "Copy / Save Buttons Size", 50, 0.5, function(a) updateTextSize("ActionButtons", math.floor(9 + a * 14)) end},
        {"slider", "Regular Buttons Size", 50, 0.5, function(a) updateTextSize("Buttons", math.floor(9 + a * 16)) end},
        {"slider", "Slider Text Size", 50, 0.5, function(a) updateTextSize("Sliders", math.floor(9 + a * 16)) end},
        {"slider", "Input Fields Size", 50, 0.5, function(a) updateTextSize("Inputs", math.floor(8 + a * 14)) end},
        {"slider", "Palette Text Size", 50, 0.5, function(a) updateTextSize("Palettes", math.floor(8 + a * 14)) end},
        {"slider", "Other Text Size", 50, 0.5, function(a) updateTextSize("Labels", math.floor(9 + a * 16)) end},
    },

    Cursor = {
        {"section", "Cursor"},
        {"toggle", "Enable Cursor", function(v)
            cur.enabled = v
            if not v then
                cur.frame.Visible = false
                UserInputService.MouseIconEnabled = true
                cur.inside = false
            end
        end},
        {"toggle", "Spin", function(v)
            cur.spinEnabled = v
            if not v then
                cur.angle = 0
                cur.ring.Rotation = 0
                cur.ch.Rotation  = 0
                cur.cv.Rotation  = 0
            end
        end},
        {"slider", "Spin Speed", 120, 120/360, function(a) cur.spinSpeed = a * 360 end},
        {"slider", "Glow Size", 44, 44/100, function(a)
            local s = math.floor(a * 100 + 0.5)
            cur.glow.Size = UDim2.fromOffset(s, s)
        end},
        {"slider", "Ring Size", 22, 22/100, function(a)
            local s = math.floor(a * 100 + 0.5)
            cur.ring.Size = UDim2.fromOffset(s, s)
        end},
        {"slider", "Dot Size", 4, 4/100, function(a)
            local s = math.max(1, math.floor(a * 100 + 0.5))
            cur.dot.Size = UDim2.fromOffset(s, s)
        end},
        {"slider", "Cross Size", 16, 16/100, function(a)
            local s = math.max(1, math.floor(a * 100 + 0.5))
            cur.ch.Size = UDim2.fromOffset(s, 2)
            cur.cv.Size = UDim2.fromOffset(2, s)
        end},
        {"slider", "Glow Alpha", 80, 0.8, function(a) cur.glow.BackgroundTransparency = a end},
        {"slider", "Ring Alpha", 0, 0, function(a) cur.stroke.Transparency = a end},
        {"toggle", "Rainbow", function(v)
            cur.rainbow = v
        end},
        {"slider", "Rainbow Speed", 40, 0.4, function(a)
            cur.rainbowSpeed = a * 2.0
        end},
        {"colorpicker", "Cursor Color", COLORS.accent, function(c)
            if cur.rainbow then return end
            cur.glow.BackgroundColor3 = c
            cur.dot.BackgroundColor3 = c
            cur.ch.BackgroundColor3 = c
            cur.cv.BackgroundColor3 = c
            cur.stroke.Color = c
        end},
    }
}

-- ===================== BUILDER =====================
local function buildPage(page,rows,tabName)
    settingsPage=page; curSection=nil
    for _,r in ipairs(rows) do
        if     r[1]=="section"      then addSection(r[2],tabName)
        elseif r[1]=="toggle"       then addToggle(r[2],r[3])
        elseif r[1]=="button"       then addButton(r[2],r[3])
        elseif r[1]=="slider"       then addSlider(r[2],r[3],r[4],r[5])
        elseif r[1]=="input"        then local b=addInput(r[2],r[3],r[4]);
        elseif r[1]=="colorpicker"  then addColorPicker(r[2],r[3],r[4])
        elseif r[1]=="keybind"      then addKeybind(r[2],r[3],r[4])
        elseif r[1]=="rebind"       then addRebindOnly(r[2],r[3],r[4])
        end
    end
end

for _,name in ipairs(SIDE_TABS) do
    if Nav.tabPages[name] then buildPage(Nav.tabPages[name],TAB_CONTENT[name] or {},name) end
end

if Nav.rightTabPgs["Settings"] then
    buildPage(Nav.rightTabPgs["Settings"], TAB_CONTENT["Settings"] or {}, "Settings")
end

if Nav.rightTabPgs["Themes"] then
    buildPage(Nav.rightTabPgs["Themes"], TAB_CONTENT["Themes"] or {}, "Themes")
end

if Nav.rightTabPgs["Cursor"] then
    buildPage(Nav.rightTabPgs["Cursor"], TAB_CONTENT["Cursor"] or {}, "Cursor")
end

-- auto-enable cursor toggle so it starts ON
if toggleSet["Enable Cursor"] then toggleSet["Enable Cursor"](true) end

if Nav.topTabBtns[1] then selectTop(Nav.topTabBtns[1].button,Nav.topTabBtns[1].name) end

-- ===================== RESIZE HINT / COLLAPSE TO LOGO =====================
local resizeHint=Instance.new("TextButton",window)
resizeHint.AnchorPoint=Vector2.new(1,1); resizeHint.Position=UDim2.new(1,0,1,0)
resizeHint.Size=UDim2.fromOffset(12,12); resizeHint.BackgroundTransparency=.35
resizeHint.BorderSizePixel=0; resizeHint.Rotation=45; resizeHint.Text=""; resizeHint.AutoButtonColor=false
Track.BG(resizeHint)

local isCollapsed=false
local preCollapseSize, preCollapsePos = nil, nil

-- ===================== TOGGLE COOLDOWN =====================
-- –Ј–∞—Й–Є—В–∞ –Њ—В —Б–њ–∞–Љ–∞: –Њ—В–Ї—А—Л—В–Є–µ/–Ј–∞–Ї—А—Л—В–Є–µ/—Б–≤–Њ—А–∞—З–Є–≤–∞–љ–Є–µ/—А–∞–Ј–≤–Њ—А–∞—З–Є–≤–∞–љ–Є–µ –Љ–µ–љ—О
-- (–ї—О–±—Л–Љ —Б–њ–Њ—Б–Њ–±–Њ–Љ вАФ RightShift, –Ї–љ–Њ–њ–Ї–∞ "-", –Ї–ї–Є–Ї –њ–Њ –Ї—А—Г–ґ–Ї—Г, –Љ–Њ–±–Є–ї—М–љ–∞—П –Ї–љ–Њ–њ–Ї–∞)
-- –љ–µ —З–∞—Й–µ –Њ–і–љ–Њ–≥–Њ —А–∞–Ј–∞ –≤ TOGGLE_COOLDOWN —Б–µ–Ї—Г–љ–і
local TOGGLE_COOLDOWN = 1.0
local lastToggleTime = 0
local function canToggle()
    local now = os.clock()
    if now - lastToggleTime < TOGGLE_COOLDOWN then
        return false
    end
    lastToggleTime = now
    return true
end

-- small circular bubble shown only while collapsed
local collapseBubble=Instance.new("ImageButton",screenGui)
collapseBubble.Name="DyserCollapseBubble"
collapseBubble.Size=UDim2.fromOffset(54,54)
collapseBubble.BackgroundColor3=COLORS.panel2
collapseBubble.Image=""
collapseBubble.Visible=false
collapseBubble.AutoButtonColor=false
collapseBubble.ZIndex=50
corner(collapseBubble,27)
Track.Panel2BG(collapseBubble)
local collapseStroke=stroke(collapseBubble,COLORS.accent,2,.1)
table.insert(Acc.strokes,collapseStroke)

local collapseLogo=Instance.new("ImageLabel",collapseBubble)
collapseLogo.Size=UDim2.new(0.7,0,0.7,0)
collapseLogo.AnchorPoint=Vector2.new(.5,.5)
collapseLogo.Position=UDim2.fromScale(.5,.5)
collapseLogo.BackgroundTransparency=1
collapseLogo.Image="rbxassetid://85321985213119"
collapseLogo.ScaleType=Enum.ScaleType.Fit

-- –≤—Б–њ—Л—И–Ї–∞-—Н—Д—Д–µ–Ї—В: —А–∞—Б—И–Є—А—П–µ—В—Б—П –Є —В–∞–µ—В –≤ –Љ–Њ–Љ–µ–љ—В —Б—Е–ї–Њ–њ—Л–≤–∞–љ–Є—П/—А–∞—Б–Ї—А—Л—В–Є—П/—Б–≤–Њ—А–∞—З–Є–≤–∞–љ–Є—П –Љ–µ–љ—О.
-- –Ь–Њ–ґ–µ—В –±—Л—В—М –Ї—А—Г–≥–ї–Њ–є (–і–ї—П –Ї—А—Г–ґ–Ї–∞/–Љ–Є–љ–Є–Љ–Є–Ј–∞—Ж–Є–Є) –Є–ї–Є –њ—А—П–Љ–Њ—Г–≥–Њ–ї—М–љ–Њ–є —Д–Њ—А–Љ—Л –Њ–Ї–љ–∞ (–і–ї—П RightShift).
local glowRing=Instance.new("Frame",screenGui)
glowRing.Name="DyserGlowRing"
glowRing.AnchorPoint=Vector2.new(.5,.5)
glowRing.Size=UDim2.fromOffset(40,40)
glowRing.BackgroundTransparency=1
glowRing.BorderSizePixel=0
glowRing.ZIndex=49
glowRing.Visible=false
local glowCorner=corner(glowRing,1000)
local glowStroke=Instance.new("UIStroke",glowRing)
glowStroke.Color=ui.glowColor
glowStroke.Thickness=3
glowStroke.Transparency=1

-- –Ї—А—Г–≥–ї–∞—П –≤—Б–њ—Л—И–Ї–∞ (–Ї—А—Г–ґ–Њ–Ї, minimize) вАФ —Ж–µ–љ—В—А –≤ —В–Њ—З–Ї–µ, —А–∞–Ј–Љ–µ—А —А–∞—Б—В—С—В –Ї–∞–Ї –Ї–≤–∞–і—А–∞—В
local function pulseGlow(centerPos, startSize, endSize, duration)
    glowCorner.CornerRadius=UDim.new(0,1000)
    glowRing.Position=UDim2.fromOffset(centerPos.X, centerPos.Y)
    glowRing.Size=UDim2.fromOffset(startSize,startSize)
    glowRing.Visible=true
    glowStroke.Color=ui.glowColor
    glowStroke.Transparency=0.1
    glowStroke.Thickness=4
    TweenService:Create(glowRing,TweenInfo.new(duration,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),
        {Size=UDim2.fromOffset(endSize,endSize)}):Play()
    local fade=TweenService:Create(glowStroke,TweenInfo.new(duration,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),
        {Transparency=1, Thickness=0.5})
    fade:Play()
    fade.Completed:Connect(function()
        glowRing.Visible=false
    end)
end

-- –њ—А—П–Љ–Њ—Г–≥–Њ–ї—М–љ–∞—П –≤—Б–њ—Л—И–Ї–∞ —А–∞–Ј–Љ–µ—А–Њ–Љ —Б –Љ–µ–љ—О (RightShift –Њ—В–Ї—А—Л—В–Є–µ/–Ј–∞–Ї—А—Л—В–Є–µ):
-- —А–∞—Б—В—С—В –Ш–Ч –£–У–Ы–Р –Њ–Ї–љ–∞ (–∞ –љ–µ –Є–Ј —Ж–µ–љ—В—А–∞) –і–Њ –њ–Њ–ї–љ–Њ–≥–Њ —А–∞–Ј–Љ–µ—А–∞ –Њ–Ї–љ–∞, –Ї–∞–Ї —А–∞–Ј–≤–Њ—А–∞—З–Є–≤–∞—О—Й–Є–є—Б—П –≤–µ–µ—А
-- cornerAnchor: Vector2 (0,0)=top-left, (1,0)=top-right, (0,1)=bottom-left, (1,1)=bottom-right
local function pulseGlowRect(cornerPixelPos, cornerAnchor, targetWidth, targetHeight, duration)
    glowCorner.CornerRadius=UDim.new(0,12)   -- —Б–Ї—А—Г–≥–ї–µ–љ–Є–µ –Ї–∞–Ї —Г —Б–∞–Љ–Њ–≥–Њ –Њ–Ї–љ–∞, –љ–µ –Є–і–µ–∞–ї—М–љ—Л–є –Ї—А—Г–≥
    glowRing.AnchorPoint=cornerAnchor
    glowRing.Position=UDim2.fromOffset(cornerPixelPos.X, cornerPixelPos.Y)
    glowRing.Size=UDim2.fromOffset(targetWidth*0.08, targetHeight*0.08)
    glowRing.Visible=true
    glowStroke.Color=ui.glowColor
    glowStroke.Transparency=0.1
    glowStroke.Thickness=4
    TweenService:Create(glowRing,TweenInfo.new(duration,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),
        {Size=UDim2.fromOffset(targetWidth, targetHeight)}):Play()
    local fade=TweenService:Create(glowStroke,TweenInfo.new(duration,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),
        {Transparency=1, Thickness=0.5})
    fade:Play()
    fade.Completed:Connect(function()
        glowRing.Visible=false
        glowRing.AnchorPoint=Vector2.new(.5,.5)           -- –≤–Њ–Ј–≤—А–∞—Й–∞–µ–Љ —Ж–µ–љ—В—А-—П–Ї–Њ—А—М –њ–Њ —Г–Љ–Њ–ї—З–∞–љ–Є—О
        glowCorner.CornerRadius=UDim.new(0,1000)          -- –≤–Њ–Ј–≤—А–∞—Й–∞–µ–Љ –Ї—А—Г–≥–ї—Г—О —Д–Њ—А–Љ—Г –њ–Њ —Г–Љ–Њ–ї—З–∞–љ–Є—О –і–ї—П —Б–ї–µ–і. –Ї—А—Г–ґ–Ї–∞/minimize
    end)
end

-- "–°–С–Ю–†–Ъ–Р" вАФ –Њ–±—А–∞—В–љ—Л–є —Н—Д—Д–µ–Ї—В: –Ї–Њ–љ—В—Г—А —Б—В–∞—А—В—Г–µ—В —А–∞–Ј–Љ–µ—А–Њ–Љ —Б –Њ–Ї–љ–Њ –Є –°–Ц–Ш–Ь–Р–Х–Ґ–°–ѓ
-- –≤ –Љ–∞–ї–µ–љ—М–Ї—Г—О —В–Њ—З–Ї—Г —Г –Ј–∞–і–∞–љ–љ–Њ–≥–Њ —Г–≥–ї–∞. –Ш—Б–њ–Њ–ї—М–Ј—Г–µ—В—Б—П –њ—А–Є —Б–≤–Њ—А–∞—З–Є–≤–∞–љ–Є–Є (minimize),
-- —З—В–Њ–±—Л —Б–Њ–Ј–і–∞–≤–∞–ї–Њ—Б—М –Њ—Й—Г—Й–µ–љ–Є–µ "–Љ–µ–љ—О —Б—В—П–≥–Є–≤–∞–µ—В—Б—П –Є —Б–Њ–±–Є—А–∞–µ—В—Б—П" –∞ –љ–µ –≤—Б–њ—Л—Е–Є–≤–∞–µ—В –љ–∞ –Љ–µ—Б—В–µ.
local function pulseGlowShrink(startWidth, startHeight, cornerPixelPos, cornerAnchor, duration)
    glowCorner.CornerRadius=UDim.new(0,12)
    glowRing.AnchorPoint=cornerAnchor
    glowRing.Position=UDim2.fromOffset(cornerPixelPos.X, cornerPixelPos.Y)
    glowRing.Size=UDim2.fromOffset(startWidth, startHeight)
    glowRing.Visible=true
    glowStroke.Color=ui.glowColor
    glowStroke.Transparency=0.15
    glowStroke.Thickness=3
    -- –Ї–Њ–љ—В—Г—А —Б–ґ–Є–Љ–∞–µ—В—Б—П –і–Њ –Љ–∞–ї–µ–љ—М–Ї–Њ–є —В–Њ—З–Ї–Є –≤ —Г–≥–ї—Г вАФ –±—Г–і—В–Њ –≤—Б–µ –Ї—А–∞—П —Б—В—П–≥–Є–≤–∞—О—В—Б—П —В—Г–і–∞
    TweenService:Create(glowRing,TweenInfo.new(duration,Enum.EasingStyle.Quad,Enum.EasingDirection.In),
        {Size=UDim2.fromOffset(startWidth*0.06, startHeight*0.06)}):Play()
    local fade=TweenService:Create(glowStroke,TweenInfo.new(duration,Enum.EasingStyle.Quad,Enum.EasingDirection.In),
        {Transparency=1, Thickness=0.5})
    fade:Play()
    fade.Completed:Connect(function()
        glowRing.Visible=false
        glowRing.AnchorPoint=Vector2.new(.5,.5)
        glowCorner.CornerRadius=UDim.new(0,1000)
    end)
end

local function expandFromBubble()
    isCollapsed=false
    playsfx("open")

    -- –Ј–µ–ї—С–љ–∞—П –≤—Б–њ—Л—И–Ї–∞-–Ї–Њ–ї—М—Ж–Њ —В–Њ—З–љ–Њ –њ–Њ —Ж–µ–љ—В—А—Г –Ї—А—Г–ґ–Ї–∞ –≤ –Љ–Њ–Љ–µ–љ—В –µ–≥–Њ –Є—Б—З–µ–Ј–љ–Њ–≤–µ–љ–Є—П
    pulseGlow(Vector2.new(collapseBubble.AbsolutePosition.X+collapseBubble.AbsoluteSize.X/2, collapseBubble.AbsolutePosition.Y+collapseBubble.AbsoluteSize.Y/2), 20, 110, .5)

    -- 1. –њ—Г–Ј—Л—А—М –Љ–µ–і–ї–µ–љ–љ–Њ "—Б–ґ–Є–Љ–∞–µ—В—Б—П" –Є —В–∞–µ—В, –ї–Њ–≥–Њ –њ—А–Њ–Ї—А—Г—З–Є–≤–∞–µ—В—Б—П –љ–∞–њ–Њ—Б–ї–µ–і–Њ–Ї
    local shrink = TweenService:Create(collapseBubble, TweenInfo.new(.32,Enum.EasingStyle.Quad,Enum.EasingDirection.In),
        {Size=UDim2.fromOffset(14,14), BackgroundTransparency=1})
    local fadeStroke = TweenService:Create(collapseStroke, TweenInfo.new(.32,Enum.EasingStyle.Quad,Enum.EasingDirection.In),
        {Transparency=1})
    local spinOut = TweenService:Create(collapseLogo, TweenInfo.new(.32,Enum.EasingStyle.Quad,Enum.EasingDirection.In),
        {Rotation=collapseLogo.Rotation+120, ImageTransparency=1})
    shrink:Play(); fadeStroke:Play(); spinOut:Play()
    shrink.Completed:Wait()

    -- –Ј–µ–ї—С–љ–∞—П –≤—Б–њ—Л—И–Ї–∞ —А–∞–Ј–Љ–µ—А–Њ–Љ —Б –±—Г–і—Г—Й–µ–µ –Њ–Ї–љ–Њ, —А–∞—Б—В—С—В –Є–Ј –ї–µ–≤–Њ–≥–Њ –≤–µ—А—Е–љ–µ–≥–Њ —Г–≥–ї–∞ вАФ
    -- —В–∞–Ї–Њ–є –ґ–µ —Н—Д—Д–µ–Ї—В, –Ї–∞–Ї –њ—А–Є –Њ–±—Л—З–љ–Њ–Љ –Њ—В–Ї—А—Л—В–Є–Є –Љ–µ–љ—О, –∞ –љ–µ –Ї—А—Г–≥–ї—Л–є
    local restoreSize = isMin and UDim2.new((preCollapseSize or fullSize).X.Scale,(preCollapseSize or fullSize).X.Offset,0,30) or (preCollapseSize or fullSize)
    local finalPosForGlow = preCollapsePos or window.Position
    local glowW = restoreSize.X.Scale * screenGui.AbsoluteSize.X + restoreSize.X.Offset
    local glowH = restoreSize.Y.Scale * screenGui.AbsoluteSize.Y + restoreSize.Y.Offset
    local glowX = finalPosForGlow.X.Scale * screenGui.AbsoluteSize.X + finalPosForGlow.X.Offset
    local glowY = finalPosForGlow.Y.Scale * screenGui.AbsoluteSize.Y + finalPosForGlow.Y.Offset
    pulseGlowRect(Vector2.new(glowX, glowY), Vector2.new(0,0), glowW, glowH, .65)

    collapseBubble.Visible=false
    collapseLogo.Rotation=0
    collapseLogo.ImageTransparency=0
    collapseBubble.BackgroundTransparency=0
    collapseStroke.Transparency=.1

    -- 2. –Њ–Ї–љ–Њ –њ–Њ—П–≤–ї—П–µ—В—Б—П –Є–Ј —В–Њ–є –ґ–µ —В–Њ—З–Ї–Є, –Љ–∞–ї–µ–љ—М–Ї–Є–Љ –Є –њ–Њ–ї–љ–Њ—Б—В—М—О –њ—А–Њ–Ј—А–∞—З–љ—Л–Љ
    window.Visible=true
    window.Size=UDim2.fromOffset(40,40)
    window.Position=collapseBubble.Position
    window.BackgroundTransparency=1
    if windowStroke then windowStroke.Transparency=1 end
    topBar.BackgroundTransparency=1
    local savedBodyTransp = body.BackgroundTransparency
    body.BackgroundTransparency=1

    if not isMin then
        body.Visible=true
    end

    -- 3. —А–∞—Б—В—П–≥–Є–≤–∞–µ–Љ –Њ–Ї–љ–Њ –Є –Њ–і–љ–Њ–≤—А–µ–Љ–µ–љ–љ–Њ –њ—А–Њ—П–≤–ї—П–µ–Љ –µ–≥–Њ –Є –Ї–Њ–љ—В–µ–љ—В –≤–љ—Г—В—А–Є вАФ –Љ–µ–і–ї–µ–љ–љ–Њ –Є –Љ—П–≥–Ї–Њ, –±–µ–Ј —А—Л–≤–Ї–∞
    TweenService:Create(window,TweenInfo.new(.75,Enum.EasingStyle.Quint,Enum.EasingDirection.Out),
        {Size=restoreSize, Position=preCollapsePos or window.Position, BackgroundTransparency=0}):Play()
    if windowStroke then
        TweenService:Create(windowStroke,TweenInfo.new(.65,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),
            {Transparency=.35}):Play()
    end
    -- –Ї–Њ–љ—В–µ–љ—В –њ—А–Њ—П–≤–ї—П–µ—В—Б—П —З—Г—В—М –њ–Њ–Ј–ґ–µ —Б–∞–Љ–Њ–≥–Њ –Њ–Ї–љ–∞ вАФ –ї—С–≥–Ї–∞—П "–Ј–∞–і–µ—А–ґ–Ї–∞ —Б–ї–Њ—П–Љ–Є"
    task.delay(.25, function()
        if topBar and topBar.Parent then
            TweenService:Create(topBar,TweenInfo.new(.45,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{BackgroundTransparency=0}):Play()
        end
        if body and body.Parent then
            TweenService:Create(body,TweenInfo.new(.45,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{BackgroundTransparency=savedBodyTransp}):Play()
        end
    end)
end

local function collapseToCircle()
    isCollapsed=true
    preCollapseSize=window.Size
    preCollapsePos=window.Position
    playsfx("click")

    -- 1. –Ї–Њ–љ—В–µ–љ—В –≥–∞—Б–љ–µ—В –њ–µ—А–≤—Л–Љ (–Љ–µ–і–ї–µ–љ–љ—Л–є "–≤—Л–і–Њ—Е"), –Њ–Ї–љ–Њ —Б–ї–µ–і–Њ–Љ —Б–ґ–Є–Љ–∞–µ—В—Б—П
    local savedBodyTransp = body.BackgroundTransparency
    TweenService:Create(topBar,TweenInfo.new(.3,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{BackgroundTransparency=1}):Play()
    TweenService:Create(body,TweenInfo.new(.3,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{BackgroundTransparency=1}):Play()
    task.wait(.1)

    -- –Ј–∞–Љ–µ—В–љ—Л–є "–≤–і–Њ—Е" –њ–µ—А–µ–і —Б–ґ–∞—В–Є–µ–Љ –і–ї—П –њ—А—Г–ґ–Є–љ–Є—Б—В–Њ—Б—В–Є
    local punch = TweenService:Create(window, TweenInfo.new(.15,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),
        {Size=UDim2.new(preCollapseSize.X.Scale,preCollapseSize.X.Offset+8,preCollapseSize.Y.Scale,preCollapseSize.Y.Offset+6)})
    punch:Play(); punch.Completed:Wait()

    local shrink=TweenService:Create(window,TweenInfo.new(.6,Enum.EasingStyle.Quint,Enum.EasingDirection.In),
        {Size=UDim2.fromOffset(40,40), BackgroundTransparency=1})
    if windowStroke then
        TweenService:Create(windowStroke,TweenInfo.new(.4,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{Transparency=1}):Play()
    end
    shrink:Play()
    shrink.Completed:Wait()
    window.Visible=false
    window.BackgroundTransparency=0
    topBar.BackgroundTransparency=0
    body.BackgroundTransparency=savedBodyTransp
    if windowStroke then windowStroke.Transparency=.35 end

    -- 2. –њ—Г–Ј—Л—А—М –њ–Њ—П–≤–ї—П–µ—В—Б—П –љ–∞ —В–Њ–Љ –ґ–µ –Љ–µ—Б—В–µ: –Љ–∞–ї–µ–љ—М–Ї–Є–є+–њ—А–Њ–Ј—А–∞—З–љ—Л–є вЖТ —А–∞—Б—В—С—В —Б –ї—С–≥–Ї–Є–Љ overshoot, –ї–Њ–≥–Њ –Ї—А—Г—В–Є—В—Б—П –њ—А–Є –њ–Њ—П–≤–ї–µ–љ–Є–Є
    collapseBubble.Position=UDim2.fromOffset(window.AbsolutePosition.X, window.AbsolutePosition.Y)
    collapseBubble.Size=UDim2.fromOffset(10,10)
    collapseBubble.BackgroundTransparency=1
    collapseBubble.Visible=true
    collapseStroke.Transparency=1
    collapseLogo.Rotation=-100
    collapseLogo.ImageTransparency=1

    -- –Ј–µ–ї—С–љ–∞—П –≤—Б–њ—Л—И–Ї–∞-–Ї–Њ–ї—М—Ж–Њ —В–Њ—З–љ–Њ –њ–Њ —Ж–µ–љ—В—А—Г —В–Њ–≥–Њ –Љ–µ—Б—В–∞, –≥–і–µ –њ–Њ—П–≤–Є—В—Б—П –Ї—А—Г–ґ–Њ–Ї
    -- (—Д–Є–љ–∞–ї—М–љ—Л–є —А–∞–Ј–Љ–µ—А –Ї—А—Г–ґ–Ї–∞ 54x54, –њ–Њ—Н—В–Њ–Љ—Г —Ж–µ–љ—В—А = –њ–Њ–Ј–Є—Ж–Є—П + 27)
    pulseGlow(Vector2.new(collapseBubble.Position.X.Offset+27, collapseBubble.Position.Y.Offset+27), 30, 130, .6)

    TweenService:Create(collapseBubble,TweenInfo.new(.55,Enum.EasingStyle.Back,Enum.EasingDirection.Out),
        {Size=UDim2.fromOffset(54,54), BackgroundTransparency=0}):Play()
    TweenService:Create(collapseStroke,TweenInfo.new(.55,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),
        {Transparency=.1}):Play()
    TweenService:Create(collapseLogo,TweenInfo.new(.6,Enum.EasingStyle.Back,Enum.EasingDirection.Out),
        {Rotation=0, ImageTransparency=0}):Play()
end

resizeHint.MouseButton1Click:Connect(function()
    if not isCollapsed and canToggle() then collapseToCircle() end
end)

-- allow dragging the little bubble around the screen while collapsed
local bubbleDragging,bubbleDragStart,bubbleStartPos=false,nil,nil
local bubbleDidDrag=false
local BUBBLE_DRAG_THRESHOLD=4 -- pixels of movement before it counts as a drag, not a click

collapseBubble.MouseButton1Click:Connect(function()
    if isCollapsed and not bubbleDidDrag and canToggle() then expandFromBubble() end
end)

collapseBubble.InputBegan:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
        bubbleDragging=true; bubbleDidDrag=false; bubbleDragStart=i.Position; bubbleStartPos=collapseBubble.Position
    end
end)
collapseBubble.InputEnded:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
        bubbleDragging=false
    end
end)
table.insert(scriptConnections, UserInputService.InputChanged:Connect(function(i)
    if bubbleDragging and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
        local delta=i.Position-bubbleDragStart
        if not bubbleDidDrag and (math.abs(delta.X)>BUBBLE_DRAG_THRESHOLD or math.abs(delta.Y)>BUBBLE_DRAG_THRESHOLD) then
            bubbleDidDrag=true
        end
        collapseBubble.Position=UDim2.fromOffset(bubbleStartPos.X.Offset+delta.X, bubbleStartPos.Y.Offset+delta.Y)
    end
end))

-- ===================== CLOSE =====================
table.insert(scriptConnections,closeBtn.MouseButton1Click:Connect(function()
    playsfx("click"); UserInputService.MouseIconEnabled = true
    for _,c in ipairs(scriptConnections) do if c and c.Connected then c:Disconnect() end end
    table.clear(scriptConnections)
    if screenGui then screenGui:Destroy() end
end))

-- ===================== MAXIMIZE (removed вАФ kept as inert constant for downstream code) =====================
local isMaxed=false
local preMaxSize, preMaxPos = nil, nil

local function applyMaximizedSize()
    -- no-op: maximize feature removed
end

screenGui:GetPropertyChangedSignal("AbsoluteSize"):Connect(applyMaximizedSize)

-- ===================== MINIMIZE =====================
fullSize=window.Size; local fullMin=szLim.MinSize; isMin=false
local _minimizeGen = 0
minimizeBtn.MouseButton1Click:Connect(function()
    if not canToggle() then return end
    playsfx("click")
    if isMin then
        isMin=false; body.Visible=true; szLim.MinSize=fullMin
        _minimizeGen = _minimizeGen + 1
        minimizeBtn.Text="-"
        -- restore to maximized size if it was maximized before minimizing,
        -- otherwise restore to its normal pre-minimize size
        local restoreSize
        if isMaxed then
            local sz = screenGui.AbsoluteSize
            restoreSize = UDim2.fromOffset(sz.X, sz.Y)
            window.Position = UDim2.fromOffset(0,0)
        else
            restoreSize = fullSize
        end
        -- –Ј–µ–ї—С–љ–∞—П –≤—Б–њ—Л—И–Ї–∞ —А–∞–Ј–Љ–µ—А–Њ–Љ —Б –Њ–Ї–љ–Њ, —А–∞—Б—В—С—В –Є–Ј –ї–µ–≤–Њ–≥–Њ –≤–µ—А—Е–љ–µ–≥–Њ —Г–≥–ї–∞, –≤ –Љ–Њ–Љ–µ–љ—В –≤–Њ—Б—Б—В–∞–љ–Њ–≤–ї–µ–љ–Є—П –Є–Ј –Љ–Є–љ–Є-–њ–Њ–ї–Њ—Б–Ї–Є
        local rw = restoreSize.X.Scale * screenGui.AbsoluteSize.X + restoreSize.X.Offset
        local rh = restoreSize.Y.Scale * screenGui.AbsoluteSize.Y + restoreSize.Y.Offset
        pulseGlowRect(Vector2.new(window.AbsolutePosition.X, window.AbsolutePosition.Y), Vector2.new(0,0), rw, rh, .5)
        TweenService:Create(window,TweenInfo.new(.6,Enum.EasingStyle.Quint,Enum.EasingDirection.Out), {Size=restoreSize}):Play()
        TweenService:Create(minimizeBtn,TweenInfo.new(.35),{TextColor3=COLORS.text}):Play()
    else
        isMin=true; minimizeBtn.Text="вЦ°"
        TweenService:Create(minimizeBtn,TweenInfo.new(.25),{TextColor3=COLORS.accent}):Play()
        local shrinkWidth = isMaxed and screenGui.AbsoluteSize.X or fullSize.X.Offset
        -- –Ј–µ–ї—С–љ–∞—П –≤—Б–њ—Л—И–Ї–∞ "—Б–Њ–±–Є—А–∞–µ—В—Б—П" –Є–Ј –њ–Њ–ї–љ–Њ–≥–Њ —А–∞–Ј–Љ–µ—А–∞ –Њ–Ї–љ–∞ –≤ —В–Њ—З–Ї—Г —Г –ї–µ–≤–Њ–≥–Њ –≤–µ—А—Е–љ–µ–≥–Њ —Г–≥–ї–∞ вАФ
        -- —Н—Д—Д–µ–Ї—В —Б—В—П–≥–Є–≤–∞–љ–Є—П/—Б–±–Њ—А–Ї–Є, —Б–Є–љ—Е—А–Њ–љ–љ—Л–є —Б–Њ —Б–ґ–∞—В–Є–µ–Љ —Б–∞–Љ–Њ–≥–Њ –Њ–Ї–љ–∞ –≤ –њ–Њ–ї–Њ—Б–Ї—Г
        pulseGlowShrink(window.AbsoluteSize.X, window.AbsoluteSize.Y, Vector2.new(window.AbsolutePosition.X, window.AbsolutePosition.Y), Vector2.new(0,0), .55)
        local shrink=TweenService:Create(window,TweenInfo.new(.55,Enum.EasingStyle.Quint,Enum.EasingDirection.In), {Size=UDim2.fromOffset(shrinkWidth,30)})
        local savedBodyTransp = body.BackgroundTransparency
        body.BackgroundColor3=COLORS.windowBg
        TweenService:Create(body,TweenInfo.new(.3),{BackgroundTransparency=math.clamp(savedBodyTransp+.5,0,1)}):Play()
        _minimizeGen = _minimizeGen + 1
        local myGen = _minimizeGen
        task.delay(.3,function()
            if myGen ~= _minimizeGen then return end -- state changed (un-minimized/maximized) while waiting
            body.Visible=false; body.BackgroundTransparency=savedBodyTransp
            szLim.MinSize=Vector2.new(fullMin.X,30)
            shrink:Play()
        end)
    end
end)

-- ===================== MAXIMIZE (removed) =====================

-- ===================== DRAG =====================
local dragging,dragStart,startPosAbs=false,nil,nil
table.insert(scriptConnections,topBar.InputBegan:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true; dragStart=i.Position; startPosAbs=window.AbsolutePosition end
end))
table.insert(scriptConnections,topBar.InputEnded:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
end))
table.insert(scriptConnections,UserInputService.InputChanged:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseMovement then
        if dragging and dragStart then
            local d=i.Position-dragStart
            local newX = startPosAbs.X+d.X
            local newY = startPosAbs.Y+d.Y
            -- –љ–µ –і–∞—С–Љ –њ–µ—А–µ—В–∞—Й–Є—В—М –Њ–Ї–љ–Њ –Ј–∞ –њ—А–µ–і–µ–ї—Л —Н–Ї—А–∞–љ–∞ (–Њ—Б–Њ–±–µ–љ–љ–Њ –≤–≤–µ—А—Е,
            -- —З—В–Њ–±—Л —В–Њ–њ–±–∞—А —Б –Ї–љ–Њ–њ–Ї–∞–Љ–Є –љ–µ —Г–ї–µ—В–∞–ї –Ј–∞ –≤–Є–і–Є–Љ—Г—О –Њ–±–ї–∞—Б—В—М)
            local screenSize = screenGui.AbsoluteSize
            local winSize = window.AbsoluteSize
            newX = math.clamp(newX, 0, math.max(0, screenSize.X - winSize.X))
            newY = math.clamp(newY, 0, math.max(0, screenSize.Y - winSize.Y))
            window.Position=UDim2.fromOffset(newX,newY)
        end
    end
end))

-- ===================== TOGGLE KEY =====================
table.insert(scriptConnections,UserInputService.InputBegan:Connect(function(input,proc)
    if input.UserInputType==Enum.UserInputType.MouseButton1 and cur.inside then cursorPulse() end
    if input.UserInputType~=Enum.UserInputType.Keyboard then return end
    if input.KeyCode==Enum.KeyCode.Delete then
        if not screenGui or not screenGui.Parent then return end
        for _,c in ipairs(scriptConnections) do if c and c.Connected then c:Disconnect() end end
        table.clear(scriptConnections)
        local killTween=TweenService:Create(window,TweenInfo.new(.35,Enum.EasingStyle.Back,Enum.EasingDirection.In),
            {Size=UDim2.new(0,0,0,0),Position=UDim2.new(MENU_POS.x+MENU_SIZE.x/2,0,MENU_POS.y+MENU_SIZE.y/2,0)})
        UserInputService.MouseIconEnabled = true
        killTween:Play(); killTween.Completed:Wait()
        if screenGui then screenGui:Destroy() end
        return
    end
    if TOGGLE_KEY and input.KeyCode==TOGGLE_KEY then
        if not screenGui or not screenGui.Parent then return end
        if not canToggle() then return end
        if isCollapsed then
            -- –Љ–µ–љ—О —Б–≤—С—А–љ—Г—В–Њ –≤ –Ї—А—Г–ґ–Њ–Ї: RightShift –њ—А—П—З–µ—В/–њ–Њ–Ї–∞–Ј—Л–≤–∞–µ—В –Є–Љ–µ–љ–љ–Њ –Ї—А—Г–ґ–Њ–Ї, –Ї—А—Г–≥–ї—Л–Љ —Н—Д—Д–µ–Ї—В–Њ–Љ
            if collapseBubble.Visible then
                pulseGlow(Vector2.new(collapseBubble.AbsolutePosition.X+collapseBubble.AbsoluteSize.X/2, collapseBubble.AbsolutePosition.Y+collapseBubble.AbsoluteSize.Y/2), 20, 100, .5)
                local t=TweenService:Create(collapseBubble,TweenInfo.new(.3,Enum.EasingStyle.Quad,Enum.EasingDirection.In),
                    {Size=UDim2.fromOffset(10,10), BackgroundTransparency=1})
                TweenService:Create(collapseStroke,TweenInfo.new(.3,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{Transparency=1}):Play()
                TweenService:Create(collapseLogo,TweenInfo.new(.3,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{ImageTransparency=1}):Play()
                t:Play(); t.Completed:Wait()
                collapseBubble.Visible=false
            else
                collapseBubble.Visible=true
                collapseBubble.Size=UDim2.fromOffset(10,10)
                collapseBubble.BackgroundTransparency=1
                collapseStroke.Transparency=1
                collapseLogo.ImageTransparency=1
                -- —Ж–µ–љ—В—А —Б—З–Є—В–∞–µ–Љ –њ–Њ –§–Ш–Э–Р–Ы–ђ–Э–Ю–Ь–£ —А–∞–Ј–Љ–µ—А—Г –Ї—А—Г–ґ–Ї–∞ (54x54), –∞ –љ–µ –њ–Њ
                -- –≤—А–µ–Љ–µ–љ–љ–Њ–Љ—Г —Б—В–∞—А—В–Њ–≤–Њ–Љ—Г (10x10) вАФ –Є–љ–∞—З–µ –≤—Б–њ—Л—И–Ї–∞ –Њ–Ї–∞–ґ–µ—В—Б—П –љ–µ –љ–∞ –Љ–µ—Б—В–µ
                pulseGlow(Vector2.new(collapseBubble.AbsolutePosition.X+27, collapseBubble.AbsolutePosition.Y+27), 10, 100, .5)
                TweenService:Create(collapseBubble,TweenInfo.new(.4,Enum.EasingStyle.Back,Enum.EasingDirection.Out),
                    {Size=UDim2.fromOffset(54,54), BackgroundTransparency=0}):Play()
                TweenService:Create(collapseStroke,TweenInfo.new(.4,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Transparency=.1}):Play()
                TweenService:Create(collapseLogo,TweenInfo.new(.4,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{ImageTransparency=0}):Play()
                playsfx("open")
            end
            return
        end
        if screenGui.Enabled then
            -- –Ј–µ–ї—С–љ–∞—П –≤—Б–њ—Л—И–Ї–∞ —А–∞–Ј–Љ–µ—А–Њ–Љ —Б –Љ–µ–љ—О—И–Ї—Г, —А–∞—Б—В—С—В –Є–Ј –ї–µ–≤–Њ–≥–Њ –≤–µ—А—Е–љ–µ–≥–Њ —Г–≥–ї–∞ –Њ–Ї–љ–∞
            pulseGlowRect(Vector2.new(window.AbsolutePosition.X, window.AbsolutePosition.Y), Vector2.new(0,0), window.AbsoluteSize.X, window.AbsoluteSize.Y, .6)
            local t=TweenService:Create(window,TweenInfo.new(.55,Enum.EasingStyle.Quint,Enum.EasingDirection.In),
             {Size=UDim2.new(MENU_SIZE.x,0,0,0),Position=UDim2.new(MENU_POS.x,0,MENU_POS.y+.1,0)})
            t:Play(); t.Completed:Wait(); screenGui.Enabled=false
            UserInputService.MouseIconEnabled=true; cur.inside=false; if cur.frame then cur.frame.Visible=false end
        else
            local tgt
            if isMin then
                -- minimized takes visual priority; width matches whatever
                -- state (maximized or normal) it was minimized from
                szLim.MinSize=Vector2.new(fullMin.X,30)
                local w = isMaxed and screenGui.AbsoluteSize.X or fullSize.X.Offset
                tgt = UDim2.fromOffset(w,30)
            elseif isMaxed then
                local sz = screenGui.AbsoluteSize
                szLim.MaxSize=Vector2.new(math.huge,math.huge)
                szLim.MinSize=fullMin
                tgt = UDim2.fromOffset(sz.X, sz.Y)
            else
                szLim.MinSize=fullMin
                tgt = fullSize
            end
            screenGui.Enabled=true
            window.Size=UDim2.new(MENU_SIZE.x,0,0,0); window.Position=UDim2.new(MENU_POS.x,0,MENU_POS.y+.1,0)
            -- –Ј–µ–ї—С–љ–∞—П –≤—Б–њ—Л—И–Ї–∞ —А–∞–Ј–Љ–µ—А–Њ–Љ —Б –Љ–µ–љ—О—И–Ї—Г –≤ –Љ–Њ–Љ–µ–љ—В –Њ—В–Ї—А—Л—В–Є—П –њ–Њ RightShift
            -- —Б—З–Є—В–∞–µ–Љ —Ж–µ–љ—В—А –њ–Њ –§–Ш–Э–Р–Ы–ђ–Э–Ю–Щ –њ–Њ–Ј–Є—Ж–Є–Є/—А–∞–Ј–Љ–µ—А—Г –Њ–Ї–љ–∞, –∞ –љ–µ –њ–Њ —В–µ–Ї—Г—Й–µ–Љ—Г (—Б—Е–ї–Њ–њ–љ—Г—В–Њ–Љ—Г –≤ –њ–Њ–ї–Њ—Б–Ї—Г) —Б–Њ—Б—В–Њ—П–љ–Є—О
            local finalPos = (isMaxed and not isMin) and UDim2.fromOffset(0,0) or UDim2.new(MENU_POS.x,0,MENU_POS.y,0)
            local tgtW = tgt.X.Scale * screenGui.AbsoluteSize.X + tgt.X.Offset
            local tgtH = tgt.Y.Scale * screenGui.AbsoluteSize.Y + tgt.Y.Offset
            local finalX = finalPos.X.Scale * screenGui.AbsoluteSize.X + finalPos.X.Offset
            local finalY = finalPos.Y.Scale * screenGui.AbsoluteSize.Y + finalPos.Y.Offset
            pulseGlowRect(Vector2.new(finalX, finalY), Vector2.new(0,0), tgtW, tgtH, .7)
            TweenService:Create(window,TweenInfo.new(.75,Enum.EasingStyle.Quint,Enum.EasingDirection.Out),
                {Size=tgt,Position=finalPos}):Play()
            playsfx("open")
        end
        return
    end
    if waitingBind then
        local newKey = (input.KeyCode==Enum.KeyCode.Escape or input.KeyCode==Enum.KeyCode.Backspace) and nil or input.KeyCode
        if waitingBind.isRebindOnly and waitingBind.setKey then
            waitingBind.setKey(newKey)
        else
            waitingBind.keyCode=newKey
            waitingBind.button.Text=newKey and newKey.Name or "None"
        end
        waitingBind=nil; return
    end
    if proc then return end
    for _,b in ipairs(keybinds) do if not b.isRebindOnly and b.keyCode==input.KeyCode and b.setActive then b.setActive(not b.active) end end
end))

-- ===================== [CROSSPLATFORM] MOBILE BUTTON =====================
