-- вФАвФА –Т—Б–њ–Њ–Љ–Њ–≥–∞—В–µ–ї—М–љ–∞—П —Д—Г–љ–Ї—Ж–Є—П: —Б–Њ–Ј–і–∞—С—В –љ–Њ–≤—Г—О –≤–µ—А—Е–љ—О—О –≤–Ї–ї–∞–і–Ї—Г —Б –Ю–Ґ–Ф–Х–Ы–ђ–Э–Ю–Щ –±–Њ–Ї–Њ–≤–Њ–є –њ–∞–љ–µ–ї—М—О
-- –Ъ–∞–ґ–і–∞—П –≤–µ—А—Е–љ—П—П –≤–Ї–ї–∞–і–Ї–∞ —З–µ—А–µ–Ј API –њ–Њ–ї—Г—З–∞–µ—В —Б–≤–Њ—О —Б–Њ–±—Б—В–≤–µ–љ–љ—Г—О –±–Њ–Ї–Њ–≤—Г—О –њ–∞–љ–µ–ї—М (–Є–Ј–Њ–ї–Є—А–Њ–≤–∞–љ–љ–Њ
-- –Њ—В —Б–Є—Б—В–µ–Љ–љ—Л—Е –≤–Ї–ї–∞–і–Њ–Ї Main/Profiles/Theme –Є –і—А—Г–≥ –Њ—В –і—А—Г–≥–∞).

local function createTopTabBtn(name)
    local btn = label(topTabsFrame, "TextButton", {
        Size      = UDim2.fromOffset(56, 22),
        BackgroundTransparency = 0,
        BackgroundColor3 = Color3.fromRGB(8,8,9),
        Text = "", TextSize = TSIZES.tab, Font = FONTS.bold,
        AutoButtonColor = false, Category = "TopTabs",
    })
    corner(btn, 3); stroke(btn, COLORS.lineLight, 1, .25); bubble(btn, 6, true)
    local lbl2 = label(btn, "TextLabel", {
        Size = UDim2.new(1,0,1,0), Text = name, TextSize = TSIZES.tab,
        Font = FONTS.bold, TextXAlignment = Enum.TextXAlignment.Center,
        TextColor3 = COLORS.text, Category = "TopTabs",
    })
    lbl2.ZIndex = 10
    regSearch(name, name, btn)
    bindCursorHover(btn)
    local sc = Instance.new("UIScale", btn)
    btn.MouseEnter:Connect(function()
        TweenService:Create(sc, TweenInfo.new(.15), {Scale=1.05}):Play()
        if btn ~= Nav.selectedTop then TweenService:Create(btn, TweenInfo.new(.15), {BackgroundColor3=Color3.fromRGB(15,15,16)}):Play() end
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(sc, TweenInfo.new(.15), {Scale=1}):Play()
        if btn ~= Nav.selectedTop then TweenService:Create(btn, TweenInfo.new(.15), {BackgroundColor3=Color3.fromRGB(8,8,9)}):Play() end
    end)

    -- –°–Њ–Ј–і–∞—С–Љ –Њ—В–і–µ–ї—М–љ—Г—О –±–Њ–Ї–Њ–≤—Г—О –њ–∞–љ–µ–ї—М –і–ї—П —Н—В–Њ–є –≤–µ—А—Е–љ–µ–є –≤–Ї–ї–∞–і–Ї–Є
    -- –Њ–љ–∞ –ґ–Є–≤—С—В –њ–Њ–≤–µ—А—Е —Б–Є—Б—В–µ–Љ–љ–Њ–≥–Њ sidePanel –Є –њ–Њ–Ї–∞–Ј—Л–≤–∞–µ—В—Б—П —В–Њ–ї—М–Ї–Њ –Ї–Њ–≥–і–∞ –∞–Ї—В–Є–≤–љ–∞ —Н—В–∞ –≤–Ї–ї–∞–і–Ї–∞
    local apiPanel = Instance.new("ScrollingFrame", body)
    apiPanel.Name = name.."_SidePanel"
    apiPanel.Size = UDim2.new(0, SIZES.sideW, 1, 0)
    apiPanel.BorderSizePixel = 0
    apiPanel.ScrollingDirection = Enum.ScrollingDirection.Y
    apiPanel.ScrollBarThickness = 3
    apiPanel.CanvasSize = UDim2.fromOffset(0,0)
    apiPanel.AutomaticCanvasSize = Enum.AutomaticSize.Y
    apiPanel.Visible = false
    apiPanel.ZIndex = 6
    Track.Scrollbar(apiPanel)
    Track.PanelBG(apiPanel)
    pad(apiPanel, 5, 5, 8, 0)
    local apiLL = Instance.new("UIListLayout", apiPanel)
    apiLL.Padding = UDim.new(0, 6); apiLL.SortOrder = Enum.SortOrder.LayoutOrder

    -- –Ю—В–і–µ–ї—М–љ—Л–є leftPane (–Ї–Њ–љ—В–µ–є–љ–µ—А —Б—В—А–∞–љ–Є—Ж) –і–ї—П —Н—В–Њ–є –≤–µ—А—Е–љ–µ–є –≤–Ї–ї–∞–і–Ї–Є
    local apiLeftPane = Instance.new("Frame", contentZone)
    apiLeftPane.Name = name.."_LeftPane"
    apiLeftPane.Size = UDim2.new(0, 408, 1, 0)
    apiLeftPane.BorderSizePixel = 0
    apiLeftPane.ClipsDescendants = true
    apiLeftPane.Visible = false
    Track.WindowBG(apiLeftPane)

    apiSidePanels[name] = {
        panel = apiPanel,
        leftPane = apiLeftPane,
        sideButtons = {},
        selectedSide = nil,
    }

    Nav.topToSide[name] = {}
    table.insert(Nav.topTabBtns, {button=btn, label=lbl2, name=name})

    btn.MouseButton1Click:Connect(function()
        playsfx("click")
        -- —Б–Ї—А—Л–≤–∞–µ–Љ —Б–Є—Б—В–µ–Љ–љ—Г—О –±–Њ–Ї–Њ–≤—Г—О –њ–∞–љ–µ–ї—М –Є –≤—Б–µ API-–њ–∞–љ–µ–ї–Є
        sidePanel.Visible = false
        leftPane.Visible  = false
        for n, data in pairs(apiSidePanels) do
            data.panel.Visible    = false
            data.leftPane.Visible = false
        end
        -- –њ–Њ–Ї–∞–Ј—Л–≤–∞–µ–Љ —Б–≤–Њ—О
        apiPanel.Visible    = true
        apiLeftPane.Visible = true
        -- –њ–Њ–і—Б–≤–µ—З–Є–≤–∞–µ–Љ –≤–µ—А—Е–љ—О—О –Ї–љ–Њ–њ–Ї—Г
        for _, e in ipairs(Nav.topTabBtns) do
            e.button.BackgroundColor3 = Color3.fromRGB(8,8,9)
            if e.label then e.label.TextColor3 = COLORS.text end
        end
        Nav.selectedTop = btn
        btn.BackgroundColor3 = COLORS.accent
        lbl2.TextColor3 = COLORS.white
        -- —Б–Ї—А—Л–≤–∞–µ–Љ —Б–Є—Б—В–µ–Љ–љ—Л–є bottomBtn (–Њ–љ —В–Њ–ї—М–Ї–Њ –і–ї—П "Main")
        if Nav.sideBottomBtn then Nav.sideBottomBtn.Visible = false end
        -- –∞–Ї—В–Є–≤–Є—А—Г–µ–Љ –њ–µ—А–≤—Г—О –±–Њ–Ї–Њ–≤—Г—О –Ї–љ–Њ–њ–Ї—Г —Н—В–Њ–є –≤–Ї–ї–∞–і–Ї–Є
        local data = apiSidePanels[name]
        if data and data.sideButtons[1] then
            local first = data.sideButtons[1]
            first.btn.BackgroundColor3 = COLORS.accent
            if data.selectedSide then data.selectedSide.Visible = false end
            first.page.Visible = true
            data.selectedSide = first.page
            settingsPage = first.page
        end
    end)

    return btn
end

-- вФАвФА –°–Њ–Ј–і–∞—С—В –±–Њ–Ї–Њ–≤—Г—О –≤–Ї–ї–∞–і–Ї—Г –≤–љ—Г—В—А–Є –Ї–Њ–љ–Ї—А–µ—В–љ–Њ–є –≤–µ—А—Е–љ–µ–є –≤–Ї–ї–∞–і–Ї–Є (–Є–Ј–Њ–ї–Є—А–Њ–≤–∞–љ–љ–Њ)
local function createSideTabEntry(topName, sideName)
    local data = apiSidePanels[topName]
    if not data then return Instance.new("ScrollingFrame") end

    local btn = label(data.panel, "TextButton", {
        Size = UDim2.new(1, 0, 0, SIZES.rowH),
        BackgroundColor3 = Color3.fromRGB(17,17,18),
        Text = "", Font = Enum.Font.Gotham,
        AutoButtonColor = false, TextColor3 = COLORS.white,
    })
    corner(btn, 4)
    stroke(btn, COLORS.lineLight, 1, .2)
    local activeStroke = stroke(btn, COLORS.accent, 1, 0); activeStroke.Transparency = 1
    table.insert(Acc.strokes, activeStroke)
    local gr = gradient(btn, Color3.fromRGB(23,23,24), Color3.fromRGB(9,9,10), 90)
    bubble(btn, 8, true)
    local lbl3 = label(btn, "TextLabel", {
        Size = UDim2.new(1,0,1,0), Text = sideName,
        TextSize = TSIZES.sideTab, Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Center, TextColor3 = COLORS.text,
    })
    lbl3.TextScaled = true; lbl3.ZIndex = 10; pad(lbl3, 4, 4)
    bindCursorHover(btn)
    local uiSc = Instance.new("UIScale", btn)
    btn.MouseEnter:Connect(function() TweenService:Create(uiSc, TweenInfo.new(.15), {Scale=1.02}):Play() end)
    btn.MouseLeave:Connect(function() TweenService:Create(uiSc, TweenInfo.new(.15), {Scale=1}):Play() end)

    -- –°—В—А–∞–љ–Є—Ж–∞ –Ї–Њ–љ—В–µ–љ—В–∞ вАФ –ґ–Є–≤—С—В –≤ –Њ—В–і–µ–ї—М–љ–Њ–Љ leftPane —Н—В–Њ–є –≤–µ—А—Е–љ–µ–є –≤–Ї–ї–∞–і–Ї–Є
    local page = Instance.new("ScrollingFrame", data.leftPane)
    page.Name = sideName.."Page"
    page.Size = UDim2.new(1, 0, 1, 0)
    page.BorderSizePixel = 0
    Track.WindowBG(page)
    page.ScrollBarThickness = 3; Track.Scrollbar(page)
    page.CanvasSize = UDim2.fromOffset(0,0); page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    page.Visible = false; pad(page, 6, 2, 2)
    local pLL = Instance.new("UIListLayout", page)
    pLL.SortOrder = Enum.SortOrder.LayoutOrder; pLL.Padding = UDim.new(0,0)

    local entry = {btn = btn, page = page, name = sideName}
    table.insert(data.sideButtons, entry)

    -- –µ—Б–ї–Є —Н—В–Њ –њ–µ—А–≤–∞—П –±–Њ–Ї–Њ–≤–∞—П –Ї–љ–Њ–њ–Ї–∞ вАФ –њ–Њ–Ї–∞–Ј—Л–≤–∞–µ–Љ –µ—С —Б—А–∞–Ј—Г (–њ—А–Є –∞–Ї—В–Є–≤–∞—Ж–Є–Є –≤–µ—А—Е–љ–µ–є –≤–Ї–ї–∞–і–Ї–Є)
    if #data.sideButtons == 1 then
        btn.BackgroundColor3 = COLORS.accent
    end

    btn.MouseButton1Click:Connect(function()
        playsfx("click")
        -- —Б–Ї—А—Л–≤–∞–µ–Љ –≤—Б–µ —Б—В—А–∞–љ–Є—Ж—Л —Н—В–Њ–є –≤–µ—А—Е–љ–µ–є –≤–Ї–ї–∞–і–Ї–Є, –њ–Њ–Ї–∞–Ј—Л–≤–∞–µ–Љ –≤—Л–±—А–∞–љ–љ—Г—О
        for _, e in ipairs(data.sideButtons) do
            e.btn.BackgroundColor3 = Color3.fromRGB(17,17,18)
            e.page.Visible = false
        end
        btn.BackgroundColor3 = COLORS.accent
        page.Visible = true
        data.selectedSide = page
        settingsPage = page
    end)

    return page
end

-- вФАвФА SideTab –Њ–±—К–µ–Ї—В вАФ —В–Њ, —З–µ—А–µ–Ј —З—В–Њ –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї—М –і–Њ–±–∞–≤–ї—П–µ—В —Н–ї–µ–Љ–µ–љ—В—Л
local function makeSideTabAPI(page, sideName)
    local api = {}

    -- –њ–µ—А–µ–і –Ї–∞–ґ–і—Л–Љ –≤—Л–Ј–Њ–≤–Њ–Љ builder-—Д—Г–љ–Ї—Ж–Є–Є –љ—Г–ґ–љ–Њ –њ–µ—А–µ–Ї–ї—О—З–Є—В—М settingsPage –љ–∞ –љ—Г–ґ–љ—Г—О —Б—В—А–∞–љ–Є—Ж—Г
    local function withPage(fn)
        local prev = settingsPage
        settingsPage = page
        curSection = nil
        fn()
        settingsPage = prev
    end

    function api:AddSection(txt)
        withPage(function() addSection(txt, sideName) end)
        return self
    end

    function api:AddToggle(opts)
        -- opts: { Text, Default, Callback }
        withPage(function()
            local cb = opts.Callback
            addToggle(opts.Text or "Toggle", cb)
            -- –њ—А–Є–Љ–µ–љ—П–µ–Љ –Ј–љ–∞—З–µ–љ–Є–µ –њ–Њ —Г–Љ–Њ–ї—З–∞–љ–Є—О —З–µ—А–µ–Ј toggleSetters
            if opts.Default and Nav.ipairts then end
            local key = opts.Text or "Toggle"
            if opts.Default ~= nil and toggleSet and toggleSet[key] then
                toggleSet[key](opts.Default)
            end
        end)
        return self
    end

    function api:AddButton(opts)
        -- opts: { Text, Callback, DoubleClick }
        withPage(function() addButton(opts.Text or "Button", opts.Callback) end)
        return self
    end

    function api:AddSlider(opts)
        -- opts: { Text, Min, Max, Default, Callback }
        local min  = opts.Min     or 0
        local max  = opts.Max     or 100
        local def  = opts.Default or min
        local scale = (max - min) > 0 and (def - min) / (max - min) or 0
        withPage(function() addSlider(opts.Text or "Slider", def, scale, opts.Callback) end)
        return self
    end

    function api:AddInput(opts)
        -- opts: { Text, Default, Callback }
        withPage(function() addInput(opts.Text or "Input", opts.Default or "", opts.Callback) end)
        return self
    end

    function api:AddKeybind(opts)
        -- opts: { Text, Default, Callback }
        withPage(function() addKeybind(opts.Text or "Keybind", opts.Default, opts.Callback) end)
        return self
    end

    function api:AddColorPicker(opts)
        -- opts: { Text, Default, Callback }
        withPage(function() addColorPicker(opts.Text or "Color", opts.Default or Color3.fromRGB(255,255,255), opts.Callback) end)
        return self
    end

    -- –і–Њ—Б—В—Г–њ –Ї —Б–∞–Љ–Њ–Љ—Г ScrollingFrame –µ—Б–ї–Є –љ—Г–ґ–µ–љ –і–ї—П –Ї–∞—Б—В–Њ–Љ–љ–Њ–≥–Њ –Ї–Њ–і–∞
    function api:GetPage() return page end

    return api
end

-- вФАвФА TopTab –Њ–±—К–µ–Ї—В
local function makeTopTabAPI(topName)
    local api = {}

    function api:AddSideTab(sideName)
        local page = createSideTabEntry(topName, sideName)
        return makeSideTabAPI(page, sideName)
    end

    function api:GetName() return topName end

    return api
end

-- вФАвФА –У–ї–∞–≤–љ—Л–є –Њ–±—К–µ–Ї—В Window
local WindowAPI = {}

function WindowAPI:AddTopTab(name)
    createTopTabBtn(name)
    return makeTopTabAPI(name)
end

-- –Я–µ—А–µ–Ї–ї—О—З–Є—В—М—Б—П –љ–∞ –љ—Г–ґ–љ—Г—О –≤–µ—А—Е–љ—О—О –≤–Ї–ї–∞–і–Ї—Г –њ—А–Њ–≥—А–∞–Љ–Љ–љ–Њ
function WindowAPI:SelectTopTab(name)
    for _, e in ipairs(Nav.topTabBtns) do
        if e.name == name then selectTop(e.button, name); break end
    end
end

-- –Я–µ—А–µ–Ї–ї—О—З–Є—В—М—Б—П –љ–∞ –љ—Г–ґ–љ—Г—О –±–Њ–Ї–Њ–≤—Г—О –≤–Ї–ї–∞–і–Ї—Г –њ—А–Њ–≥—А–∞–Љ–Љ–љ–Њ
function WindowAPI:SelectSideTab(name)
    for _, e in ipairs(Nav.sideButtons) do
        if e.name == name then selectSide(e.button, e.gradient, name, e.page); break end
    end
end

-- вФАвФА –Ъ–Њ—А–љ–µ–≤–Њ–є –Њ–±—К–µ–Ї—В –±–Є–±–ї–Є–Њ—В–µ–Ї–Є
local DyserLib = {}

-- –Я–Њ–ї—Г—З–Є—В—М –Њ–±—К–µ–Ї—В –Њ–Ї–љ–∞ (—Г –љ–∞—Б –Њ–і–љ–Њ –Њ–Ї–љ–Њ, —Б–Њ–Ј–і–∞—С—В—Б—П –∞–≤—В–Њ–Љ–∞—В–Є—З–µ—Б–Ї–Є)
function DyserLib:GetWindow()
    return WindowAPI
end

-- –Ф–Њ–±–∞–≤–Є—В—М –ї–Њ–≥ —Б–љ–∞—А—Г–ґ–Є
function DyserLib:AddLog(text, color)
    AddLog(text, color)
end

-- –°–Љ–µ–љ–Є—В—М –∞–Ї—Ж–µ–љ—В–љ—Л–є —Ж–≤–µ—В —Б–љ–∞—А—Г–ґ–Є
function DyserLib:SetAccent(color)
    setAccent(color)
end

-- –°–Љ–µ–љ–Є—В—М —Д–Њ–љ –Њ–Ї–љ–∞
function DyserLib:SetWindowBG(color)
    if setWindowBackground then setWindowBackground(color) end
end

-- –Т–Ї–ї—О—З–Є—В—М/–≤—Л–Ї–ї—О—З–Є—В—М –Ј–≤—Г–Ї–Є
function DyserLib:SetSoundEnabled(state)
    sfxEnabled = state
end

-- –Я—А–Њ—З–Є—В–∞—В—М/–Ј–∞–њ–Є—Б–∞—В—М —Б–Њ—Б—В–Њ—П–љ–Є–µ —В–Њ–≥–ї–Њ–≤ (–і–ї—П –Є–љ—В–µ–≥—А–∞—Ж–Є–Є —Б –Ї–Њ–љ—Д–Є–≥–∞–Љ–Є)
function DyserLib:SetToggle(name, value)
    if toggleSet and toggleSet[name] then toggleSet[name](value) end
end

function DyserLib:GetToggleState(name)
    return menuState and menuState.toggles and menuState.toggles[name]
end

function DyserLib:SetSlider(name, value)
    if sliderSet and sliderSet[name] then sliderSet[name](value) end
end

-- –Т–Њ–Ј–≤—А–∞—Й–∞–µ–Љ —В–∞–±–ї–Є—Ж—Г –љ–∞—А—Г–ґ—Г вАФ —Н—В–Њ —В–Њ, —З—В–Њ –њ–Њ–ї—Г—З–∞–µ—В –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї—М —З–µ—А–µ–Ј loadstring(...)()
return DyserLib

end -- end of __init

-- –Ч–∞–њ—Г—Б–Ї–∞–µ–Љ –Є –≤–Њ–Ј–≤—А–∞—Й–∞–µ–Љ Library –љ–∞—А—Г–ґ—Г
return __init()
