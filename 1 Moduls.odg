local isUIBubbles = true

local Nav = {sideButtons={}, tabPages={}, topTabBtns={}, rightTabBtns={}, rightTabPgs={}, topToSide={}, selectedTop=nil, selectedSide=nil, selectedRight=nil, sideBottomBtn=nil}
for _, t in ipairs(TOP_TABS) do Nav.topToSide[t.name] = t.side end

-- —В–∞–±–ї–Є—Ж–∞ –Є–Ј–Њ–ї–Є—А–Њ–≤–∞–љ–љ—Л—Е –±–Њ–Ї–Њ–≤—Л—Е –њ–∞–љ–µ–ї–µ–є –і–ї—П –≤–Ї–ї–∞–і–Њ–Ї –і–Њ–±–∞–≤–ї–µ–љ–љ—Л—Е —З–µ—А–µ–Ј API
-- –Њ–±—К—П–≤–ї—П–µ–Љ –Ј–і–µ—Б—М —З—В–Њ–±—Л selectTop –Љ–Њ–≥ –µ—С –≤–Є–і–µ—В—М (–Њ–љ–∞ –Ј–∞–њ–Њ–ї–љ—П–µ—В—Б—П –њ–Њ–Ј–ґ–µ —З–µ—А–µ–Ј AddTopTab)
local apiSidePanels = {}

-- forward-–Њ–±—К—П–≤–ї–µ–љ–Є—П GUI-—Д—А–µ–є–Љ–Њ–≤ вАФ —Б–Њ–Ј–і–∞—О—В—Б—П –њ–Њ–Ј–ґ–µ, –љ–Њ –љ—Г–ґ–љ—Л –≤ selectTop/selectSide –≤—Л—И–µ
local sidePanel, leftPane, contentZone, body

-- (Nav.selectedTop/Nav.selectedSide/Nav.selectedRight/Nav.sideBottomBtn now live in Nav table above)
