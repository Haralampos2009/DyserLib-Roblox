    btn.MouseLeave:Connect(function() TweenService:Create(uiScaleSideBtn,TweenInfo.new(.15),{Scale=1}):Play() end)

    local page=Instance.new("ScrollingFrame",leftPane)
    page.Name=name.."Page"; page.Size=UDim2.new(1,0,1,0)
    page.BorderSizePixel=0
    Track.WindowBG(page)
    page.ScrollBarThickness=3; Track.Scrollbar(page)
    page.CanvasSize=UDim2.fromOffset(0,0); page.AutomaticCanvasSize=Enum.AutomaticSize.Y;
    page.Visible=false
    pad(page,6,2,2)
    local pLL=Instance.new("UIListLayout",page); pLL.SortOrder=Enum.SortOrder.LayoutOrder; pLL.Padding=UDim.new(0,0)

    Nav.tabPages[name]=page
    local entry={button=btn,gradient=gr,fillGrad=fillGrad,activeStroke=activeStroke,inactiveStroke=inactiveStroke,name=name,page=page}
    table.insert(Nav.sideButtons,entry)
    regSearch(name,name,btn)
    btn.MouseButton1Click:Connect(function() 
        playsfx("click")
        selectSide(btn,gr,name,page) 
    end)
end

