-- вФАвФА SIDE PANEL HOVER EXPAND вФАвФА
-- –Я–ї–∞–≤–љ–Њ —А–∞—Б—И–Є—А—П–µ—В –±–Њ–Ї–Њ–≤—Г—О –њ–∞–љ–µ–ї—М –њ—А–Є –љ–∞–≤–µ–і–µ–љ–Є–Є –Ї—Г—А—Б–Њ—А–∞, –љ–µ –і–≤–Є–≥–∞—П
-- –Њ—Б—В–∞–ї—М–љ–Њ–є layout (mainZone/divider –Њ—Б—В–∞—О—В—Б—П –љ–∞ –Љ–µ—Б—В–µ, –њ–∞–љ–µ–ї—М –њ—А–Њ—Б—В–Њ
-- "–љ–∞–µ–Ј–ґ–∞–µ—В" –њ–Њ–≤–µ—А—Е –љ–Є—Е –±–ї–∞–≥–Њ–і–∞—А—П —Г–≤–µ–ї–Є—З–µ–љ–љ–Њ–Љ—Г ZIndex).
do
    local SIDE_EXPANDED_W = SIZES.sideW + 48

    sidePanel.ZIndex = 6
    Nav.sideBottomBtn.ZIndex = 7

    local sideExpandTween = TweenInfo.new(.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local sideCollapseTween = TweenInfo.new(.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

    local function expandSide()
        TweenService:Create(sidePanel, sideExpandTween, {Size = UDim2.new(0, SIDE_EXPANDED_W, 1, 0)}):Play()
        TweenService:Create(Nav.sideBottomBtn, sideExpandTween, {Size = UDim2.new(0, SIDE_EXPANDED_W - 10, 0, SIZES.rowH)}):Play()
    end
    local function collapseSide()
        TweenService:Create(sidePanel, sideCollapseTween, {Size = UDim2.new(0, SIZES.sideW, 1, 0)}):Play()
        TweenService:Create(Nav.sideBottomBtn, sideCollapseTween, {Size = UDim2.new(0, SIZES.sideW - 10, 0, SIZES.rowH)}):Play()
    end

    sidePanel.MouseEnter:Connect(expandSide)
    Nav.sideBottomBtn.MouseEnter:Connect(expandSide)

    sidePanel.MouseLeave:Connect(collapseSide)
    Nav.sideBottomBtn.MouseLeave:Connect(collapseSide)
end

