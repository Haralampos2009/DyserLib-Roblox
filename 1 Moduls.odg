local clearBtn=label(searchFrame,"TextButton",{AnchorPoint=Vector2.new(1,.5),Position=UDim2.new(1,-3,.5,0), Size=UDim2.fromOffset(20,18),BackgroundColor3=Color3.fromRGB(20,20,22), Text="X",TextSize=11,TextColor3=COLORS.muted,Font=FONTS.bold,AutoButtonColor=false, Category="Buttons"})
corner(clearBtn,3); stroke(clearBtn,COLORS.line,1,.2); clearBtn.Visible=false; bindCursorHover(clearBtn)

local function doSearch(term)
    clearHighlight()
    if term=="" then clearBtn.Visible=false; searchBox.PlaceholderText="Search elements..."; return end
    clearBtn.Visible=true
    term=string.lower(term)

    -- split the search term into individual words so "rainbow cursor"
    -- also matches an element named "Cursor Rainbow" (any word order)
    local queryWords = {}
    for w in term:gmatch("%S+") do table.insert(queryWords, w) end

    local found=0; local firstTab=nil
    for _,e in ipairs(searchElements) do
        local nameLower = string.lower(e.name)
        local matches
        if string.find(nameLower,term,1,true) then
            -- exact substring match (handles single-word queries / exact phrase)
            matches = true
        else
            -- otherwise require every query word to appear somewhere in the name
            matches = true
            for _,w in ipairs(queryWords) do
                if not string.find(nameLower,w,1,true) then
                    matches = false
                    break
                end
            end
        end
        if matches then
            found=found+1
            if e.elem and e.elem.Parent and e.elem:IsA("GuiObject") then
                local ot,oc=e.elem.BackgroundTransparency,e.elem.BackgroundColor3
                table.insert(searchHighlighted,{row=e.elem,t=ot,c=oc})
                e.elem.BackgroundColor3=scaledC(COLORS.accent,.18)
                e.elem.BackgroundTransparency=0
            end
            if not firstTab then firstTab=e.tab end
        end
    end
    searchBox.PlaceholderText=found>0 and found.." found" or "No results"
    if firstTab then
        local switchedSide = false
        for _,e in ipairs(Nav.topTabBtns) do
            if e.name==firstTab then selectTop(e.button, e.name); switchedSide = true; break end
        end
        if not switchedSide then
            for _,e in ipairs(Nav.sideButtons) do
                if e.name==firstTab then selectSide(e.button,e.gradient,e.name,e.page); switchedSide = true; break end
            end
        end
        if not switchedSide then
            for _,e in ipairs(Nav.rightTabBtns) do
                if e.name==firstTab then selectRight(e.button,e.name,Nav.rightTabPgs[e.name]); break end
            end
        end
    end
end

searchBox.Changed:Connect(function(p) if p=="Text" then doSearch(searchBox.Text) end end)
searchBox.FocusLost:Connect(function(enter) if enter then doSearch(searchBox.Text) end end)
clearBtn.MouseButton1Click:Connect(function() playsfx("click"); searchBox.Text=""; searchBox.PlaceholderText="Search elements..."; clearHighlight(); clearBtn.Visible=false end)

for i,name in ipairs(RIGHT_TABS) do
    local btn=label(rTabCont,"TextButton",{Size=UDim2.fromOffset(70,19),BackgroundTransparency=0, BackgroundColor3=i==1 and COLORS.accent or Color3.fromRGB(8,8,9),Text="", TextSize=10,Font=FONTS.bold,AutoButtonColor=false})
    corner(btn,3); stroke(btn,COLORS.lineLight,1,.25); bubble(btn,6,true)
    local lbl4=label(btn,"TextLabel",{Size=UDim2.new(1,0,1,0),Text=name,TextSize=10,Font=FONTS.bold, TextXAlignment=Enum.TextXAlignment.Center,TextColor3=i==1 and COLORS.white or COLORS.text, Category="TopTabs"})
    lbl4.ZIndex=10
    
