-- ===================== SCALE AND TEXT COLOR SYSTEM =====================
local textCaches = {
    TopTabs = {},
    SideTabs = {},
    ActionButtons = {},
    Buttons = {},
    Sliders = {},
    Labels = {},
    Inputs = {},
    Palettes = {}
}
local dynamicTextElements = {}

local function trackText(category, obj)
    if obj then table.insert(textCaches[category] or textCaches.Labels, obj) end
end

local function trackColorText(o)
    if o then table.insert(dynamicTextElements, o) end
end

local function updateTextSize(category, size)
    if not textCaches[category] then return end
    for _, obj in ipairs(textCaches[category]) do
        if obj and obj.Parent then
            obj.TextSize = size
        end
    end
end

local function setTextColor(color)
    COLORS.text = color
    for _, o in ipairs(dynamicTextElements) do
        if o and o.Parent then
            local isSelected = false
            
            for _, btnData in ipairs(Nav.topTabBtns) do
                if btnData.label == o and btnData.button == Nav.selectedTop then isSelected = true end
            end
            for _, btnData in ipairs(Nav.rightTabBtns) do
                if btnData.label == o and btnData.button == Nav.selectedRight then isSelected = true end
            end
            if o.Name == "SideTabText" then
                for _, btnData in ipairs(Nav.sideButtons) do
                    if btnData.button == o.Parent and btnData.button == Nav.selectedSide then isSelected = true end
                end
            end
            
            if not isSelected then
                o.TextColor3 = color
            end
        end
    end
end

-- ===================== UTILITIES =====================
local function scaledC(c,s) return Color3.new(math.clamp(c.R*s,0,1),math.clamp(c.G*s,0,1),math.clamp(c.B*s,0,1)) end
local function corner(p,r) local c=Instance.new("UICorner"); c.CornerRadius=UDim.new(0,r); c.Parent=p; return c end
local function stroke(p,col,th,tr)
    local s=Instance.new("UIStroke"); s.Color=col; s.Thickness=th or 1
    s.Transparency=tr or 0; s.ApplyStrokeMode=Enum.ApplyStrokeMode.Border; s.Parent=p; return s
end
local function gradient(p,a,b,rot)
    local g=Instance.new("UIGradient"); g.Color=ColorSequence.new(a,b); g.Rotation=rot or 90; g.Parent=p; return g
end
local function label(p, cls, props)
    local category = props.Category
    props.Category = nil
    
    local o=Instance.new(cls)
    o.BackgroundTransparency=props.BackgroundTransparency or 1
    o.Text=props.Text or ""; 
    local isStandardColor = (props.TextColor3 == nil or props.TextColor3 == COLORS.text)
    o.TextColor3=props.TextColor3 or COLORS.text
    
    o.TextSize=props.TextSize or 14; o.Font=props.Font or Enum.Font.Code
    o.TextXAlignment=props.TextXAlignment or Enum.TextXAlignment.Left
    o.TextYAlignment=props.TextYAlignment or Enum.TextYAlignment.Center
    o.BorderSizePixel=0
    
    if cls == "TextLabel" or cls == "TextButton" or cls == "TextBox" then
        o.TextScaled = false
    end

    for k,v in pairs(props) do pcall(function() o[k]=v end) end
    if p then o.Parent=p end
    
    if isStandardColor then
        trackColorText(o)
    end
    trackText(category or "Labels", o)
    
    return o
end
local function pad(p,l,r,t,b)
    local u=Instance.new("UIPadding",p)
    if l then u.PaddingLeft=UDim.new(0,l) end; if r then u.PaddingRight=UDim.new(0,r) end
    if t then u.PaddingTop=UDim.new(0,t) end; if b then u.PaddingBottom=UDim.new(0,b) end
end

-- ===================== ACCENT AND THEME =====================
local Elems = {window={}, panel={}, panel2={}, row={}, section={}, windowFrame={}, scrollbar={}}
local Track = {}
function Track.BG(o)  table.insert(Acc.bgs,o);   o.BackgroundColor3=COLORS.accent; return o end
function Track.DkBG(o) table.insert(Acc.dkBgs,o); o.BackgroundColor3=COLORS.accentDk; return o end
function Track.Stroke(s) table.insert(Acc.strokes,s); s.Color=COLORS.accent; return s end
function Track.Grad(g)   table.insert(Acc.grads,g); g.Color=ColorSequence.new(COLORS.accentDk,COLORS.accent); return g end
function Track.TextElement(o)   table.insert(Acc.texts,o);  o.TextColor3=COLORS.accent; return o end

function Track.WindowBG(o)
    table.insert(Elems.window, o)
    o.BackgroundColor3 = COLORS.windowBg
    return o
end

function Track.PanelBG(o)
    table.insert(Elems.panel, o)
    o.BackgroundColor3 = COLORS.panel
    return o
end

function Track.Panel2BG(o)
    table.insert(Elems.panel2, o)
    o.BackgroundColor3 = COLORS.panel2
    return o
end


function Track.Scrollbar(o)
    table.insert(Elems.scrollbar, o)
    o.ScrollBarImageColor3 = COLORS.scrollbar
    return o
end

local function setScrollbarColor(color)
    COLORS.scrollbar = color
    for _, o in ipairs(Elems.scrollbar) do
        if o and o.Parent then o.ScrollBarImageColor3 = color end
    end
end

local function setAccent(color)
    COLORS.accent  = color
    COLORS.accentDk= scaledC(color,0.55)
    for _,o in ipairs(Acc.bgs)    do if o.Parent then o.BackgroundColor3=COLORS.accent end end
    for _,o in ipairs(Acc.dkBgs)  do if o.Parent then o.BackgroundColor3=COLORS.accentDk end end
    for _,s in ipairs(Acc.strokes)do if s.Parent then s.Color=COLORS.accent end end
    for _,g in ipairs(Acc.grads)  do if g.Parent then g.Color=ColorSequence.new(COLORS.accentDk,COLORS.accent) end end
    for _,o in ipairs(Acc.texts)  do if o.Parent then o.TextColor3=COLORS.accent end end
    
    if Nav.selectedTop and Nav.selectedTop.Parent then Nav.selectedTop.BackgroundColor3=COLORS.accent end
    if Nav.selectedSide and Nav.selectedSide.Parent then
        Nav.selectedSide.BackgroundColor3=COLORS.accent
        for _,e in ipairs(Nav.sideButtons) do
            if e.button==Nav.selectedSide then
                if e.gradient then e.gradient.Enabled=false end
                if e.fillGrad then e.fillGrad.Enabled=true end
                break
            end
        end
    end
    if Nav.selectedRight and Nav.selectedRight.Parent then Nav.selectedRight.BackgroundColor3=COLORS.accent end
    
    local tc=scaledC(color,1.7)
    for _,p in ipairs(Acc.texParts) do
        if p.f and p.f.Parent then p.f.BackgroundColor3=tc end
        if p.s and p.s.Parent then p.s.Color=tc end
    end
end

local function setWindowBackground(color)
    COLORS.windowBg = color
    for _, o in ipairs(Elems.window) do
        if o and o.Parent then
            o.BackgroundColor3 = color
        end
    end
end

local function setPanel(color)
    COLORS.panel = color
    for _, o in ipairs(Elems.panel) do
        if o and o.Parent then
            o.BackgroundColor3 = color
        end
    end
end

local function setPanel2(color)
    COLORS.panel2 = color
    for _, o in ipairs(Elems.panel2) do
        if o and o.Parent then
            o.BackgroundColor3 = color
        end
    end
end

local function setWindowTransparency(t)
    for _, o in ipairs(Elems.window) do
        if o and o.Parent then o.BackgroundTransparency = t end
    end
end

local function setPanelTransparency(t)
    for _, o in ipairs(Elems.panel) do
        if o and o.Parent then o.BackgroundTransparency = t end
    end
end

local function setPanel2Transparency(t)
    for _, o in ipairs(Elems.panel2) do
        if o and o.Parent then o.BackgroundTransparency = t end
    end
end

local function setRowTransparency(t)
    for _, o in ipairs(Elems.row) do
        if o and o.Parent then o.BackgroundTransparency = math.max(0.02, t) end
    end
end

local function setSectionTransparency(t)
    for _, o in ipairs(Elems.section) do
        if o and o.Parent then o.BackgroundTransparency = t end
    end
end

local function setWindowFrameTransparency(t)
    for _, o in ipairs(Elems.windowFrame) do
        if o and o.Parent then o.BackgroundTransparency = t end
    end
end

-- ===================== BUBBLES =====================
local bSeed=24680
local function bubble(parent,count,noCenter,getActive,customColor,onAccent)
    parent.ClipsDescendants=true
    local function rnd() bSeed=(bSeed*1103515245+12345)%2147483648; return bSeed/2147483648 end
    
    local ic = onAccent and Color3.fromRGB(255,255,255)
              or customColor and scaledC(customColor,0.55)
              or scaledC(COLORS.accent,1.7)
    local transp = onAccent and .55 or customColor and .35 or .55
    local strokeTranp = onAccent and .7 or customColor and .45 or .25
    
    for _=1,(count or 8) do
        local d=noCenter and (3+math.floor(rnd()*4)) or (4+math.floor(rnd()*7))
        local py=noCenter and (rnd()<.5 and .04+rnd()*.2 or .76+rnd()*.2) or rnd()
        local b=Instance.new("Frame",parent)
        b.AnchorPoint=Vector2.new(.5,.5); b.Position=UDim2.new(rnd(),0,py,0)
        b.Size=UDim2.fromOffset(d,d); b.BackgroundColor3=ic; b.BackgroundTransparency=transp
        b.BorderSizePixel=0; b.ZIndex=6; b.Active=false
        b.Visible=customColor and true or (isUIBubbles and (getActive==nil or getActive()))
        corner(b,50)
        local bs=Instance.new("UIStroke",b); bs.Color=ic; bs.Thickness=1; bs.Transparency=strokeTranp
        
        if not customColor and not onAccent then
            table.insert(Acc.texParts,{f=b,s=bs})
            table.insert(Acc.bubbles,{f=b,ga=getActive})
        elseif not customColor then
            table.insert(Acc.bubbles,{f=b,ga=getActive})
        end
    end
end
local function setBubbles(v)
    isUIBubbles=v
    for _,item in ipairs(Acc.bubbles) do
        if item.f and item.f.Parent then item.f.Visible=v and (item.ga==nil or item.ga()) end
    end
end

-- ===================== SEARCH =====================
local searchElements={}
local function regSearch(name,tab,elem)
    table.insert(searchElements,{name=name,tab=tab,elem=elem})
end
local function clearHighlight()
    for _,h in ipairs(searchHighlighted) do
        if h.row and h.row.Parent then h.row.BackgroundTransparency=h.t; h.row.BackgroundColor3=h.c end
    end
    searchHighlighted={}
end
local topTab2Label = nil

-- ===================== NAVIGATION =====================
local function showPage(page)
    for _,e in ipairs(Nav.sideButtons) do e.page.Visible=false end
    if page then page.Visible=true end
end

local function selectSide(btn,grad,name,page)
    for _,e in ipairs(Nav.sideButtons) do
        e.gradient.Enabled=true
        e.button.BackgroundColor3=Color3.fromRGB(17,17,18)
        if e.fillGrad then e.fillGrad.Enabled=false end
        if e.activeStroke then e.activeStroke.Transparency=1 end
        if e.inactiveStroke then e.inactiveStroke.Transparency=.2 end
        local lbl = e.button:FindFirstChild("SideTabText")
        if lbl then lbl.TextColor3=COLORS.text end
    end
    Nav.selectedSide=btn
    grad.Enabled=false
    btn.BackgroundColor3=COLORS.accent
    for _,e in ipairs(Nav.sideButtons) do
        if e.button==btn then
            if e.fillGrad then e.fillGrad.Enabled=true end
            if e.activeStroke then e.activeStroke.Transparency=0 end
            if e.inactiveStroke then e.inactiveStroke.Transparency=1 end
            break
        end
    end
    local actLbl = btn:FindFirstChild("SideTabText")
    if actLbl then actLbl.TextColor3=COLORS.white end
    showPage(page)
end

local function selectTop(btn,name)
    for _,e in ipairs(Nav.topTabBtns) do
        e.button.BackgroundColor3=Color3.fromRGB(8,8,9)
        if e.label then e.label.TextColor3=COLORS.text end
    end
    Nav.selectedTop=btn
    btn.BackgroundColor3=COLORS.accent
    for _,e in ipairs(Nav.topTabBtns) do
        if e.button==btn and e.label then e.label.TextColor3=COLORS.white end
    end
    -- —Б–Ї—А—Л–≤–∞–µ–Љ –≤—Б–µ API-–њ–∞–љ–µ–ї–Є (–Њ–љ–Є –њ—А–Є–љ–∞–і–ї–µ–ґ–∞—В –≤–Ї–ї–∞–і–Ї–∞–Љ –і–Њ–±–∞–≤–ї–µ–љ–љ—Л–Љ —З–µ—А–µ–Ј AddTopTab)
    if apiSidePanels then
        for _, data in pairs(apiSidePanels) do
            if data.panel and data.panel.Parent then data.panel.Visible = false end
            if data.leftPane and data.leftPane.Parent then data.leftPane.Visible = false end
        end
    end
    -- –њ–Њ–Ї–∞–Ј—Л–≤–∞–µ–Љ —Б–Є—Б—В–µ–Љ–љ—Г—О –±–Њ–Ї–Њ–≤—Г—О –њ–∞–љ–µ–ї—М –Є leftPane
    if sidePanel and sidePanel.Parent then sidePanel.Visible = true end
    if leftPane and leftPane.Parent then leftPane.Visible = true end
    local allowed=Nav.topToSide[name] or {}
    local allowSet={}; for _,n in ipairs(allowed) do allowSet[n]=true end
    for _,e in ipairs(Nav.sideButtons) do
        e.button.Visible=allowSet[e.name]==true
    end
    local first=nil
    for _,n in ipairs(allowed) do
        for _,e in ipairs(Nav.sideButtons) do
            if e.name==n then first=e; break end
        end
        if first then break end
    end
    if first then selectSide(first.button,first.gradient,first.name,first.page)
    else showPage(nil) end

    if Nav.sideBottomBtn then
        Nav.sideBottomBtn.Visible = (name == "Main")
    end
end

local function selectRight(btn,name,page)
    for _,e in ipairs(Nav.rightTabBtns) do
        e.button.BackgroundColor3=Color3.fromRGB(8,8,9)
        if e.label then e.label.TextColor3=COLORS.text end
    end
    Nav.selectedRight=btn
    btn.BackgroundColor3=COLORS.accent
    for _,e in ipairs(Nav.rightTabBtns) do
        if e.button==btn and e.label then e.label.TextColor3=COLORS.white end
    end
    for _,p in pairs(Nav.rightTabPgs) do p.Visible=false end
    if page then page.Visible=true end
end

-- ===================== GUI INIT =====================
local old=playerGui:FindFirstChild("DyserMenu"); if old then old:Destroy() end
local screenGui=Instance.new("ScreenGui",playerGui)
screenGui.Name="DyserMenu"; screenGui.IgnoreGuiInset=true
screenGui.ResetOnSpawn=false; screenGui.ZIndexBehavior=Enum.ZIndexBehavior.Sibling
screenGui.DisplayOrder=2147483647

-- ===================== LOGS =====================
local logCont=Instance.new("Frame",screenGui)
logCont.AnchorPoint=Vector2.new(1,1); logCont.Position=UDim2.new(1,-20,1,-20)
logCont.Size=UDim2.new(0,250,1,-40); logCont.BackgroundTransparency=1
local logLL=Instance.new("UIListLayout",logCont)
logLL.SortOrder=Enum.SortOrder.LayoutOrder; logLL.VerticalAlignment=Enum.VerticalAlignment.Bottom; logLL.Padding=UDim.new(0,8)

local function AddLog(text,col)
    col=col or COLORS.accent
    local f=Instance.new("Frame",logCont)
    f.Size=UDim2.new(1,0,0,30); f.BackgroundColor3=COLORS.panel; f.BackgroundTransparency=1; corner(f,4)
    local s=stroke(f,col,1,1)
    local t=label(f,"TextLabel",{Size=UDim2.new(1,-16,1,0),Position=UDim2.fromOffset(8,0),Text=text,TextColor3=COLORS.white,TextSize=12,Font=FONTS.bold,TextTransparency=1})
    TweenService:Create(f,TweenInfo.new(.3),{BackgroundTransparency=.1}):Play()
    TweenService:Create(s,TweenInfo.new(.3),{Transparency=0}):Play()
    TweenService:Create(t,TweenInfo.new(.3),{TextTransparency=0}):Play()
    task.delay(3.5,function()
        if not f.Parent then return end
        local a=TweenService:Create(f,TweenInfo.new(.5),{BackgroundTransparency=1})
        TweenService:Create(s,TweenInfo.new(.5),{Transparency=1}):Play()
        TweenService:Create(t,TweenInfo.new(.5),{TextTransparency=1}):Play()
        a:Play(); a.Completed:Wait(); f:Destroy()
    end)
end
