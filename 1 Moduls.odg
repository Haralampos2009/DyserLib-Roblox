local histClearBtn2 = label(histDateHdr,"TextButton",{ AnchorPoint=Vector2.new(1,.5), Position=UDim2.new(1,-4,.5,0), Size=UDim2.fromOffset(52,20), BackgroundColor3=Color3.fromRGB(18,6,6), Text="Clear", TextSize=10, Font=FONTS.bold, TextColor3=COLORS.pink, AutoButtonColor=false, Category="Buttons"})
