        if c:IsA("Frame") and c~=histDateHdr then c:Destroy() end
    end
    historyCount=0
end)

addHistoryEntry = function(txt, col, revertFn)
    if not historyPage or not historyPage.Parent then return end
    historyCount = historyCount + 1
    local ts = os.date and os.date("%H:%M:%S") or ("+"..historyCount)

    local row = Instance.new("Frame", historyPage)
    row.Size = UDim2.new(1,0,0,36); row.BackgroundColor3 = Color3.fromRGB(7,7,9)
    row.BackgroundTransparency = historyCount%2==0 and .05 or .12
    row.BorderSizePixel = 0; row.LayoutOrder = historyCount

    local sep = Instance.new("Frame",row)
    sep.Size=UDim2.new(0,3,1,-4); sep.Position=UDim2.fromOffset(0,2)
    sep.BackgroundColor3 = col or COLORS.accent; sep.BorderSizePixel=0; corner(sep,2)

    local textW = revertFn and UDim2.new(1,-82,0,20) or UDim2.new(1,-40,0,20)

    local tl = label(row,"TextLabel",{ Position=UDim2.fromOffset(10,2), Size=textW, Text=txt, TextSize=12, Font=Enum.Font.GothamBold, TextColor3=col or COLORS.text, TextXAlignment=Enum.TextXAlignment.Left, TextTruncate=Enum.TextTruncate.AtEnd, Category="Labels"})
    local tsl = label(row,"TextLabel",{ Position=UDim2.fromOffset(10,20), Size=UDim2.new(1,-82,0,14), Text="вП±  "..ts, TextSize=10, Font=Enum.Font.Code, TextColor3=COLORS.muted, TextXAlignment=Enum.TextXAlignment.Left, Category="Labels"})
    local numLbl = label(row,"TextLabel",{ AnchorPoint=Vector2.new(1,1), Position=UDim2.new(1,-4,1,-2), Size=UDim2.fromOffset(28,12), Text="#"..historyCount, TextSize=9, Font=Enum.Font.Code, TextColor3=Color3.fromRGB(45,45,50), TextXAlignment=Enum.TextXAlignment.Right, Category="Labels"})

    if revertFn then
        local reverted = false
        local revertBtn = label(row,"TextButton",{ AnchorPoint=Vector2.new(1,.5), Position=UDim2.new(1,-4,.5,0), Size=UDim2.fromOffset(38,26), BackgroundColor3=Color3.fromRGB(10,18,10), Text="вЖ© ", TextSize=13, Font=FONTS.bold, TextColor3=Color3.fromRGB(90,220,110), AutoButtonColor=false, Category="Buttons"})
        corner(revertBtn,4); stroke(revertBtn,Color3.fromRGB(30,60,30),1,.2); bindCursorHover(revertBtn)
        revertBtn.MouseEnter:Connect(function() if not reverted then TweenService:Create(revertBtn,TweenInfo.new(.12),{BackgroundColor3=Color3.fromRGB(20,50,20)}):Play() end end)
        revertBtn.MouseLeave:Connect(function() if not reverted then TweenService:Create(revertBtn,TweenInfo.new(.12),{BackgroundColor3=Color3.fromRGB(10,18,10)}):Play() end end)
        revertBtn.MouseButton1Click:Connect(function()
            if reverted then return end
            reverted = true
            playsfx("click")
            pcall(revertFn)
            revertBtn.Text="вЬУ"
            revertBtn.TextColor3=COLORS.muted
            TweenService:Create(revertBtn,TweenInfo.new(.2),{BackgroundColor3=Color3.fromRGB(6,10,6)}):Play()
            stroke(revertBtn,Color3.fromRGB(15,30,15),1,.4)
            TweenService:Create(sep,TweenInfo.new(.2),{BackgroundColor3=COLORS.muted}):Play()
            TweenService:Create(tl,TweenInfo.new(.2),{TextColor3=COLORS.muted}):Play()
            addHistoryEntry("вЖ© Reverted: "..txt, COLORS.muted, nil)
        end)
    end
    task.defer(function() if historyPage and historyPage.Parent then historyPage.CanvasPosition = Vector2.new(0, math.max(0, historyPage.AbsoluteCanvasSize.Y - historyPage.AbsoluteSize.Y)) end end)
end

